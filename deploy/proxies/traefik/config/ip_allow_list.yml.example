# OPTIONAL — restrict panel access by IP (Traefik).
#
# Rename to `ip_allow_list.yml` and add the `rezeis-ip-allow-list` middleware
# to the router in `rezeis.yml` to enable. Replace REPLACE_WITH_YOUR_IP with
# your allowed IP or CIDR range.
#
# If your domain is proxied by Cloudflare (orange cloud), the real client IP
# arrives inside the Cloudflare edge ranges — list them under `excludedIPs`
# so the strategy looks past them. Keep the list current:
# https://www.cloudflare.com/ips/

http:
  middlewares:
    rezeis-ip-allow-list:
      ipAllowList:
        sourceRange:
          - "REPLACE_WITH_YOUR_IP"
        ipStrategy:
          excludedIPs:
            - 173.245.48.0/20
            - 103.21.244.0/22
            - 103.22.200.0/22
            - 103.31.4.0/22
            - 141.101.64.0/18
            - 108.162.192.0/18
            - 190.93.240.0/20
            - 188.114.96.0/20
            - 197.234.240.0/22
            - 198.41.128.0/17
            - 162.158.0.0/15
            - 104.16.0.0/13
            - 104.24.0.0/14
            - 172.64.0.0/13
            - 131.0.72.0/22
