{
  "name": "rezeis-admin",
  "version": "1.0.0",
  "description": "Rezeis Admin NestJS microservice baseline",
  "private": true,
  "license": "UNLICENSED",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "test": "node --require ts-node/register --test test/**/*.spec.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "lint": "tsc --noEmit -p tsconfig.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"prisma/**/*.prisma\" \"*.json\""
  },
  "dependencies": {
    "@nestjs/axios": "4.0.1",
    "@nestjs/bullmq": "11.0.4",
    "@nestjs/common": "11.1.19",
    "@nestjs/config": "4.0.3",
    "@nestjs/core": "11.1.19",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/microservices": "11.1.19",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.19",
    "@nestjs/swagger": "11.2.6",
    "@nestjs/terminus": "11.1.1",
    "@prisma/client": "6.19.0",
    "axios": "1.15.0",
    "bullmq": "5.74.1",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.2",
    "helmet": "8.1.0",
    "ioredis": "5.10.1",
    "nest-winston": "1.10.2",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "winston": "3.19.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.21",
    "@nestjs/schematics": "11.0.9",
    "@nestjs/testing": "11.1.19",
    "@types/express": "5.0.3",
    "@types/node": "24.12.2",
    "@types/passport-jwt": "4.0.1",
    "@types/supertest": "6.0.3",
    "eslint": "9.39.4",
    "prettier": "3.8.1",
    "prisma": "6.19.0",
    "supertest": "7.1.4",
    "ts-loader": "9.5.7",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3"
  }
}
