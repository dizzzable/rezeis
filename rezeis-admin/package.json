{
  "name": "rezeis-admin",
  "version": "0.2.2",
  "description": "Rezeis Admin NestJS microservice baseline",
  "private": true,
  "license": "UNLICENSED",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "test": "node --require ts-node/register --test test/**/*.spec.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "lint": "eslint . && tsc --noEmit -p tsconfig.json",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"prisma/**/*.prisma\" \"*.json\"",
    "admin-cli": "ts-node -r dotenv/config -r tsconfig-paths/register scripts/admin-cli.ts"
  },
  "dependencies": {
    "@nestjs/axios": "4.0.1",
    "@nestjs/bullmq": "11.0.4",
    "@nestjs/common": "11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "11.1.19",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/microservices": "11.1.19",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.19",
    "@nestjs/platform-socket.io": "^11.1.21",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/swagger": "^11.4.3",
    "@nestjs/terminus": "11.1.1",
    "@nestjs/throttler": "6.4.0",
    "@nestjs/websockets": "^11.1.21",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@remnawave/backend-contract": "2.7.3",
    "@simplewebauthn/server": "^13.3.0",
    "axios": "^1.16.1",
    "better-sqlite3": "11.9.1",
    "bullmq": "^5.76.10",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.2",
    "helmet": "8.1.0",
    "ioredis": "5.10.1",
    "nest-winston": "1.10.2",
    "nodemailer": "7.0.3",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "socket.io": "^4.8.3",
    "tar-stream": "3.1.7",
    "winston": "3.19.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@nestjs/cli": "11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "11.1.19",
    "@types/better-sqlite3": "7.6.13",
    "@types/express": "5.0.3",
    "@types/multer": "^2.1.0",
    "@types/node": "24.12.2",
    "@types/nodemailer": "6.4.17",
    "@types/passport-jwt": "4.0.1",
    "@types/supertest": "6.0.3",
    "@types/tar-stream": "3.1.4",
    "eslint": "10.4.0",
    "prettier": "3.8.1",
    "prisma": "^7.8.0",
    "supertest": "7.1.4",
    "ts-loader": "9.5.7",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.3"
  }
}
