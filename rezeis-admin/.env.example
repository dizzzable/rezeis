# ═══════════════════════════════════════════════════════════════════════════════
#  rezeis-admin — Environment Configuration
#
#  Copy this file to .env and fill in the values marked with "change_me".
# ═══════════════════════════════════════════════════════════════════════════════

# - - - - - APPLICATION CONFIGURATION - - - - - #
REZEIS_DOMAIN=change_me
REZEIS_HOST=0.0.0.0
REZEIS_PORT=8000
REZEIS_LOCALES=ru,en
REZEIS_DEFAULT_LOCALE=ru
REZEIS_CRYPT_KEY=change_me
API_DOCS_ENABLED=false
ADMIN_CORS_ORIGINS=
ADMIN_TRUST_PROXY=disabled

# - - - - - REZEIS WEBHOOK CONFIGURATION - - - - - #
# OPTIONAL generic outbound webhook for YOUR OWN external integrations
# (monitoring, automation, analytics). rezeis POSTs every system event here.
# This is NOT the reiwa channel — reiwa receives its events automatically via
# `REIWA_URL` below (the `/api/v1/webhooks/rezeis` path is appended in code).
# Do NOT point WEBHOOK_URL at reiwa. If you have no external receiver, just
# leave WEBHOOK_ENABLED=false and ignore the URL.
WEBHOOK_ENABLED=false
WEBHOOK_URL=https://your-external-monitoring.example.com/webhook
# 64 alphanumeric characters (HMAC key for outbound webhooks). Generate, e.g.:
#   openssl rand -hex 32
# Same value must be set as REZEIS_WEBHOOK_SECRET on the reiwa side so it
# can verify our X-Rezeis-Signature on inbound webhooks. Leave empty to
# disable signing.
WEBHOOK_SECRET_HEADER=

# - - - - - REMNAWAVE CONFIGURATION - - - - - #
# Resolution mirrors reiwa's REZEIS_HOST handling:
#   • REMNAWAVE_HOST without a dot → `http://${host}:${port}` (docker service)
#   • REMNAWAVE_HOST with a dot    → `https://${host}` (public domain, port ignored)
#
# Examples:
#   1. Remnawave runs in the same docker compose network:
#      REMNAWAVE_HOST=remnawave
#      REMNAWAVE_PORT=3000
#
#   2. Remnawave is a public HTTPS panel (e.g. when developing locally
#      against the production Remnawave):
#      REMNAWAVE_HOST=panel.example.com
#      REMNAWAVE_PORT=                # left empty, ignored
#
#   3. SSH-tunneled remote Remnawave (port-forwarded to localhost:13000):
#      REMNAWAVE_HOST=localhost
#      REMNAWAVE_PORT=13000
REMNAWAVE_HOST=remnawave
REMNAWAVE_PORT=3000
REMNAWAVE_TOKEN=change_me
# Shared secret for INBOUND Remnawave webhooks. Must equal the panel's
# `WEBHOOK_SECRET_HEADER` (Remnawave .env). rezeis verifies the panel's
# `X-Remnawave-Signature` (HMAC-SHA256 over the JSON body) with this value.
# In the Remnawave panel set:
#   WEBHOOK_ENABLED=true
#   WEBHOOK_URL=https://<your-rezeis-domain>/api/webhook/remnawave   ← exact path
#   WEBHOOK_SECRET_HEADER=<same value as below>
REMNAWAVE_WEBHOOK_SECRET=change_me
REMNAWAVE_CADDY_TOKEN=
REMNAWAVE_COOKIE=

# - - - - - DATABASE CONFIGURATION - - - - - #
DATABASE_HOST=rezeis-db
DATABASE_PORT=5432
DATABASE_NAME=rezeis
DATABASE_USER=rezeis
DATABASE_PASSWORD=change_me
DATABASE_ECHO=false
DATABASE_ECHO_POOL=false
# Postgres connection-pool size.
# Leave EMPTY to auto-size to the container's memory budget (recommended):
#   small  (< ~1.5 GB) -> 5 connections
#   medium (~2-3 GB)   -> 10 connections
#   large  (>= ~4 GB)  -> 20 connections
# Set an explicit number to override the auto-sizing.
DATABASE_POOL_SIZE=
DATABASE_MAX_OVERFLOW=25
DATABASE_POOL_TIMEOUT=10
DATABASE_POOL_RECYCLE=3600

# - - - - - REDIS CONFIGURATION - - - - - #
REDIS_HOST=rezeis-redis
REDIS_PORT=6379
REDIS_NAME=0
REDIS_PASSWORD=change_me
# Redis maxmemory cap (BullMQ broker). Default 512mb is generous; on a small
# VPS you can lower it (e.g. 128mb). Keep it <= the redis container memory limit.
REDIS_MAXMEMORY=512mb

# - - - - - BACKUP CONFIGURATION - - - - - #
BACKUP_AUTO_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_TIME=00:00
BACKUP_MAX_KEEP=7
BACKUP_COMPRESSION=true
BACKUP_INCLUDE_LOGS=false
BACKUP_LOCATION=/app/data/backups
# Telegram delivery for backups and system events is configured through
# the admin panel (Settings → System Notifications → Telegram).
# No .env variables needed — chat_id and topic_id are stored in the database.

# - - - - - EMAIL (SMTP) CONFIGURATION (Optional) - - - - - #
EMAIL_ENABLED=false
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM_ADDRESS=no-reply@you.domain.com
EMAIL_FROM_NAME=Rezeis
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false

# - - - - - PROCESS ROLE (api / worker / all) - - - - - #
# Controls which scheduled (`@Cron`) jobs run in this process.
#   api    — HTTP only, schedules disabled (set on the API container)
#   worker — schedules enabled, HTTP listener never starts (worker.js)
#   all    — single-container deployments (dev, small installs)
# docker-compose.yml sets this per-container; leave unset for `all`.
RUID_PROCESS_ROLE=all

# - - - - - UPDATE CHECKER (Optional) - - - - - #
# The update widget compares the running version against the latest GitHub
# release. The upstream repos are already baked into the build as defaults
# (dizzzable/rezeis + dizzzable/reiwa), so you DON'T need to set anything for
# update checks to work. Uncomment and override only on a self-hosted fork
# that releases from its own repos.
#   REZEIS_UPDATE_REPO        — admin panel repo
#   REZEIS_REIWA_UPDATE_REPO  — reiwa user-cabinet repo
# REZEIS_UPDATE_REPO=dizzzable/rezeis
# REZEIS_REIWA_UPDATE_REPO=dizzzable/reiwa

# - - - - - REIWA INTEGRATION - - - - - #
# Public base URL of reiwa (the user-facing edge that receives our webhooks).
# admin POSTs operator events to <REIWA_URL>/api/v1/webhooks/rezeis:
#   • bot-config cache busts (reiwa.bot.invalidate)
#   • per-user notifications  (reiwa.user.notify)
#   • channel broadcasts      (reiwa.channel.broadcast)
# Each request is signed with WEBHOOK_SECRET_HEADER (X-Rezeis-Signature).
#
#   • Same VPS  (default):  http://reiwa:5000
#   • Split VPS (different host): https://<reiwa-domain>
#
# When unset (or WEBHOOK_SECRET_HEADER is unset), the push is disabled —
# bot config falls back to its 5-min TTL refresh and Telegram notifications
# stay in the cabinet feed only.
REIWA_URL=http://reiwa:5000

# - - - - - WEB PUSH (VAPID, optional) - - - - - #
# Browser push notifications for the reiwa cabinet. Generate a keypair once:
#   npx web-push generate-vapid-keys
# Leave unset to disable browser push (the cabinet hides its opt-in toggle).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=

# - - - - - ANONYMOUS SUPPORT CHAT (optional) - - - - - #
# These now seed the DEFAULTS only — the anonymous support chat is configured
# from the admin panel (Support tickets → Settings): enabled flag, guest token
# TTL, attachment caps and the Cloudflare Turnstile keys. Values below are used
# only until an operator saves settings in the panel (which then take over).
#
# Idle TTL (hours) for a guest token before its conversation can no longer
# be resumed. Default 72.
SUPPORT_GUEST_TOKEN_TTL_HOURS=72
# Where message attachments are stored on disk. Defaults to
# `data/support-attachments` (on the rezeis-data volume). This stays an env
# var (infra path) and is NOT panel-managed. Files are served only through a
# permissioned / token-checked controller, never statically.
SUPPORT_ATTACHMENTS_DIR=
# Per-attachment size cap in megabytes (decoded bytes). Default 10.
SUPPORT_ATTACHMENT_MAX_MB=10
# Max attachments per message. Default 5.
SUPPORT_ATTACHMENT_MAX_PER_MSG=5
