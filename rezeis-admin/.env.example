# ═══════════════════════════════════════════════════════════════════════════════
#  rezeis-admin — Environment Configuration
#
#  Copy this file to .env and fill in the values marked with "change_me".
# ═══════════════════════════════════════════════════════════════════════════════

# - - - - - APPLICATION CONFIGURATION - - - - - #
REZEIS_DOMAIN=change_me
REZEIS_HOST=0.0.0.0
REZEIS_PORT=8000
REZEIS_LOCALES=ru,en
REZEIS_DEFAULT_LOCALE=ru
REZEIS_CRYPT_KEY=change_me
# Explicit opt-in in every environment (including production). When true,
# Swagger UI + unauthenticated raw schemas are mounted at /api/docs,
# /api/docs-json and /api/docs-yaml. Protect them with VPN/proxy auth or an
# IP allowlist; false keeps all documentation routes unavailable.
API_DOCS_ENABLED=false
ADMIN_CORS_ORIGINS=
ADMIN_TRUST_PROXY=disabled

# - - - - - REZEIS WEBHOOK CONFIGURATION - - - - - #
# OPTIONAL generic outbound webhook for YOUR OWN external integrations
# (monitoring, automation, analytics). rezeis POSTs every system event here.
# This is NOT the reiwa channel — reiwa receives its events automatically via
# `REIWA_URL` below (the `/api/v1/webhooks/rezeis` path is appended in code).
# Do NOT point WEBHOOK_URL at reiwa. If you have no external receiver, just
# leave WEBHOOK_ENABLED=false and ignore the URL.
WEBHOOK_ENABLED=false
WEBHOOK_URL=https://your-external-monitoring.example.com/webhook
# 64 alphanumeric characters (HMAC key for outbound webhooks). Generate, e.g.:
#   openssl rand -hex 32
# Same value must be set as REZEIS_WEBHOOK_SECRET on the reiwa side so it
# can verify our X-Rezeis-Signature on inbound webhooks. Leave empty to
# disable signing.
WEBHOOK_SECRET_HEADER=

# - - - - - REMNAWAVE CONFIGURATION - - - - - #
# Resolution mirrors reiwa's REZEIS_HOST handling:
#   • REMNAWAVE_HOST without a dot → `http://${host}:${port}` (docker service)
#   • REMNAWAVE_HOST with a dot    → `https://${host}` (public domain, port ignored)
#
# Examples:
#   1. Remnawave runs in the same docker compose network:
#      REMNAWAVE_HOST=remnawave
#      REMNAWAVE_PORT=3000
#
#   2. Remnawave is a public HTTPS panel (e.g. when developing locally
#      against the production Remnawave):
#      REMNAWAVE_HOST=panel.example.com
#      REMNAWAVE_PORT=                # left empty, ignored
#
#   3. SSH-tunneled remote Remnawave (port-forwarded to localhost:13000):
#      REMNAWAVE_HOST=localhost
#      REMNAWAVE_PORT=13000
REMNAWAVE_HOST=remnawave
REMNAWAVE_PORT=3000
REMNAWAVE_TOKEN=change_me
# Shared secret for INBOUND Remnawave webhooks. Must equal the panel's
# `WEBHOOK_SECRET_HEADER` (Remnawave .env). rezeis verifies the panel's
# `X-Remnawave-Signature` (HMAC-SHA256 over the JSON body) with this value.
# In the Remnawave panel set:
#   WEBHOOK_ENABLED=true
#   WEBHOOK_URL=https://<your-rezeis-domain>/api/webhook/remnawave   ← exact path
#   WEBHOOK_SECRET_HEADER=<same value as below>
REMNAWAVE_WEBHOOK_SECRET=change_me
REMNAWAVE_CADDY_TOKEN=
REMNAWAVE_COOKIE=

# - - - - - DATABASE CONFIGURATION - - - - - #
DATABASE_HOST=rezeis-db
DATABASE_PORT=5432
DATABASE_NAME=rezeis
DATABASE_USER=rezeis
DATABASE_PASSWORD=change_me
DATABASE_ECHO=false
DATABASE_ECHO_POOL=false
# Postgres connection-pool size.
# Leave EMPTY to auto-size to the container's memory budget (recommended):
#   small  (< ~1.5 GB) -> 5 connections
#   medium (~2-3 GB)   -> 10 connections
#   large  (>= ~4 GB)  -> 20 connections
# Set an explicit number to override the auto-sizing.
DATABASE_POOL_SIZE=
DATABASE_MAX_OVERFLOW=25
DATABASE_POOL_TIMEOUT=10
DATABASE_POOL_RECYCLE=3600

# - - - - - REDIS CONFIGURATION - - - - - #
REDIS_HOST=rezeis-redis
REDIS_PORT=6379
REDIS_NAME=0
REDIS_PASSWORD=change_me
# Redis maxmemory cap (BullMQ broker). Default 512mb is generous; on a small
# VPS you can lower it (e.g. 128mb). Keep it <= the redis container memory limit.
REDIS_MAXMEMORY=512mb

# - - - - - PAYMENT / PROVISIONING THROUGHPUT - - - - - #
# Worker concurrency for the payment pipeline. Raise these to absorb bursts of
# simultaneous purchases (subscription provisioning runs in parallel instead of
# one-at-a-time). Bounded to the Remnawave panel's tolerance — start at 10 and
# tune up if the panel keeps up. Both default to 10, clamped to [1, 100].
#
# NOTE: effective parallelism is min(concurrency, DB pool). The Prisma pool is
# auto-sized per container tier (small=5 / medium=10 / large=20). If you raise
# these above the pool size, set DATABASE_POOL_SIZE to match so jobs don't queue
# waiting for a DB connection. The api + worker containers EACH run these
# processors, so real DB/panel load is ~2× the configured value.
PAYMENT_RECONCILIATION_CONCURRENCY=10
PROFILE_SYNC_CONCURRENCY=10

# - - - - - BACKUP CONFIGURATION - - - - - #
BACKUP_AUTO_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_TIME=00:00
BACKUP_MAX_KEEP=7
BACKUP_COMPRESSION=true
BACKUP_INCLUDE_LOGS=false
BACKUP_LOCATION=/app/data/backups
# Max backup file size (bytes) delivered to Telegram. Default 52428800 (50 MB,
# cloud Bot API cap). Raise to 2147483648 (2 GB) ONLY if the reiwa bot is wired
# to a self-hosted Local Bot API Server (see reiwa TELEGRAM_BOT_API_ROOT).
# Larger backups are kept locally and flagged in the completion notification.
# BACKUP_MAX_DELIVERY_BYTES=52428800
# Telegram delivery for backups and system events is configured through
# the admin panel (Settings → System Notifications → Telegram).
# No .env variables needed — chat_id and topic_id are stored in the database.

# - - - - - EMAIL (SMTP) CONFIGURATION (Optional) - - - - - #
# Powers email verification codes (link-email + password recovery) and
# event-driven user emails. ALL of these can also be set from the admin panel
# (Settings → Notifications → Email), which OVERRIDES these env defaults.
#
# Encryption is auto-selected by PORT (you rarely need the toggles):
#   • 465  → implicit TLS (SSL)         → EMAIL_USE_SSL=true
#   • 587  → STARTTLS (recommended)     → EMAIL_USE_TLS=true
#   • 25   → STARTTLS / plaintext
#
# DELIVERABILITY (to land in the inbox, not spam):
#   • Configure SPF, DKIM and DMARC on the EMAIL_FROM_ADDRESS domain.
#   • The From-address domain must MATCH the domain SPF/DKIM are set up for
#     (DMARC alignment) — e.g. send as no-reply@yourbrand.com from a server
#     authorized for yourbrand.com. Gmail/Yahoo/Outlook now require this.
#   • Email branding (name / logo / primary color) is taken automatically from
#     Settings → Customization — no separate email-branding config needed.
EMAIL_ENABLED=false
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM_ADDRESS=no-reply@you.domain.com
EMAIL_FROM_NAME=Rezeis
# Encryption toggles — usually leave as-is; PORT drives the actual mode.
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false

# - - - - - PROCESS ROLE (api / worker / all) - - - - - #
# Controls which scheduled (`@Cron`) jobs run in this process.
#   api    — HTTP only, schedules disabled (set on the API container)
#   worker — schedules enabled, HTTP listener never starts (worker.js)
#   all    — single-container deployments (dev, small installs)
# docker-compose.yml sets this per-container; leave unset for `all`.
RUID_PROCESS_ROLE=all

# - - - - - AI CHAT (OpenAI, optional) - - - - - #
# AI-powered chat assistant for user support. All values are optional;
# when OPENAI_API_KEY is unset the AI chat endpoints gracefully respond
# that the feature is not configured.
OPENAI_API_KEY=
# Custom API base URL (e.g. for OpenAI-compatible proxies). Defaults to
# https://api.openai.com/v1 when left empty.
OPENAI_API_URL=
# Model identifier (default: gpt-4o-mini).
OPENAI_MODEL=gpt-4o-mini

# - - - - - UPDATE CHECKER (Optional) - - - - - #
# The update widget compares the running version against the latest GitHub
# release. The upstream repos are already baked into the build as defaults
# (dizzzable/rezeis + dizzzable/reiwa), so you DON'T need to set anything for
# update checks to work. Uncomment and override only on a self-hosted fork
# that releases from its own repos.
#   REZEIS_UPDATE_REPO        — admin panel repo
#   REZEIS_REIWA_UPDATE_REPO  — reiwa user-cabinet repo
# REZEIS_UPDATE_REPO=dizzzable/rezeis
# REZEIS_REIWA_UPDATE_REPO=dizzzable/reiwa

# - - - - - REIWA INTEGRATION - - - - - #
# Public base URL of reiwa (the user-facing edge that receives our webhooks).
# admin POSTs operator events to <REIWA_URL>/api/v1/webhooks/rezeis:
#   • bot-config cache busts (reiwa.bot.invalidate)
#   • per-user notifications  (reiwa.user.notify)
#   • channel broadcasts      (reiwa.channel.broadcast)
# Each request is signed with WEBHOOK_SECRET_HEADER (X-Rezeis-Signature).
#
#   • Same VPS  (default):  http://reiwa:5000
#   • Split VPS (different host): https://<reiwa-domain>
#
# When unset (or WEBHOOK_SECRET_HEADER is unset), the push is disabled —
# bot config falls back to its 5-min TTL refresh and Telegram notifications
# stay in the cabinet feed only.
REIWA_URL=http://reiwa:5000

# Advertising deep links are read from Reiwa's /api/v1/public-config, so the
# admin cabinet always sends users to the Reiwa bot and web application — not
# to REZEIS_DOMAIN. These values are optional static fallbacks for an older or
# temporarily unreachable Reiwa deployment.
# REIWA_BOT_USERNAME=RezeisBot
# REIWA_WEB_BASE_URL=https://app.example.com
# MINIAPP_SHORT_NAME=

# - - - - - REZEIS SUBSCRIPTION PAGE (rezeis-subpage) - - - - - #
# rezeis-admin is the source of truth for the subscription-page config
# (branding, app catalog, baseSettings, translations). rezeis-subpage fetches
# it from the internal endpoint and re-validates it on its side.
#
# Base URL of rezeis-subpage — admin POSTs a config cache-invalidate to
# <REZEIS_SUBPAGE_URL>/internal/subpage-config/invalidate after every save so
# changes appear immediately (otherwise the subpage refreshes on its own TTL).
#   • Same VPS  (default):  http://rezeis-subpage:3010
#   • Split VPS:            https://<subpage-domain>
# Leave unset to disable the push.
REZEIS_SUBPAGE_URL=http://rezeis-subpage:3010
# Shared bearer secret for that invalidate webhook. MUST equal the subpage's
# REZEIS_SUBPAGE_WEBHOOK_SECRET. Generate: openssl rand -hex 32. Min 16 chars.
# Leave empty to disable the push.
REZEIS_SUBPAGE_WEBHOOK_SECRET=

# - - - - - QUEST PARTNER SECRETS (Phase C, optional / legacy fallback) - - - - - #
# Per-partner HMAC secrets for PARTNER_TASK quest postback callbacks, as a JSON
# object { "<partnerSlug>": "<secret>" }. Each secret signs that partner's
# signed callback (t=<sec>,v1=<hmac> over <t>.<rawBody>).
#
# PREFERRED: manage partners in the panel (Settings → Security → Quest partners) —
# those are stored AES-256-GCM-encrypted and override any slug set here. This env
# var remains as a bootstrap / fallback: a slug present only here still works, so
# existing deploys keep running after the migration to panel-managed secrets.
# Generate a secret per partner: openssl rand -hex 32.
#   QUEST_PARTNER_SECRETS={"acme":"<hex-secret>","globex":"<hex-secret>"}
QUEST_PARTNER_SECRETS=

# - - - - - WEB PUSH (VAPID, optional) - - - - - #
# Browser push notifications for the reiwa cabinet. Two ways to configure:
#   1) Admin panel → Settings → "Web-push": click "Generate keys" (recommended —
#      stored encrypted in the DB, no redeploy, includes a "send test" button).
#   2) These env vars (fallback). Generate a keypair once:
#        npx web-push generate-vapid-keys
# Panel-managed keys take precedence over these. Leave all unset AND ungenerated
# to disable browser push (the cabinet hides its opt-in toggle).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=

# - - - - - ANONYMOUS SUPPORT CHAT (optional) - - - - - #
# These now seed the DEFAULTS only — the anonymous support chat is configured
# from the admin panel (Support tickets → Settings): enabled flag, guest token
# TTL, attachment caps and the Cloudflare Turnstile keys. Values below are used
# only until an operator saves settings in the panel (which then take over).
#
# Idle TTL (hours) for a guest token before its conversation can no longer
# be resumed. Default 72.
SUPPORT_GUEST_TOKEN_TTL_HOURS=72
# Where message attachments are stored on disk. Defaults to
# `data/support-attachments` (on the rezeis-data volume). This stays an env
# var (infra path) and is NOT panel-managed. Files are served only through a
# permissioned / token-checked controller, never statically.
SUPPORT_ATTACHMENTS_DIR=
# Per-attachment size cap in megabytes (decoded bytes). Default 10.
SUPPORT_ATTACHMENT_MAX_MB=10
# Max attachments per message. Default 5.
SUPPORT_ATTACHMENT_MAX_PER_MSG=5

# - - - - - ANTI-FRAUD: SUBSCRIPTION SHARING (optional) - - - - - #
# Two detectors flag subscription sharing. ALL values below are optional —
# the defaults are safe out of the box.
#
# HWID device-overage (PRIMARY, on by default): flags a user with more
# registered devices than their plan's device limit. Device identity is the
# authoritative, low-false-positive signal — keep this on.
ANTIFRAUD_SHARING_HWID_ENABLED=true
#
# Concurrent-network detector (ADVISORY, OFF by default): IP-based detection is
# noisy — a single legitimate user roams across mobile/Wi-Fi/CGNAT and the
# Remnawave node balancer, and IPv6 privacy addresses rotate constantly. When
# enabled it counts distinct *networks* (not raw IPs) and only flags when they
# exceed the device limit by a tolerance margin; it emits LOW/MEDIUM, never HIGH.
ANTIFRAUD_SHARING_IP_ENABLED=false
# Group source IPs into networks before counting (collapses carrier/CGNAT churn
# and IPv6 privacy-address rotation). Strongly recommended.
ANTIFRAUD_SHARING_IP_NETWORK_GROUPING=true
# IPv4 / IPv6 grouping prefix lengths (e.g. /24 and /48).
ANTIFRAUD_SHARING_IP_V4_PREFIX=24
ANTIFRAUD_SHARING_IP_V6_PREFIX=48
# Tolerance added to the device limit before flagging: offender ⇔
# distinctNetworks > deviceLimit + margin. Absorbs the natural "home Wi-Fi +
# mobile" of a single user.
ANTIFRAUD_SHARING_IP_OVERAGE_MARGIN=1
# Only count connections seen within this many minutes (concurrency window).
ANTIFRAUD_SHARING_IP_WINDOW_MINUTES=10

# ── Per-user node-traffic abuse detector (Remnawave 2.8+) ─────────────────────
# Flags users whose bandwidth across nodes is a clear outlier (heavy in
# absolute terms AND far above the cohort) — usually torrenting / bulk transfer
# / a shared account. Advisory only (LOW/MEDIUM). Auto-activates once the panel
# reports 2.8+ (uses bandwidth-stats/nodes/users); silently inactive before.
ANTIFRAUD_NODE_TRAFFIC_USER_ENABLED=true
# Absolute floor — ignore anyone below this many GB over the panel window.
ANTIFRAUD_NODE_TRAFFIC_MIN_GB=200
# Flag when a user's traffic is at least this multiple of the cohort median.
ANTIFRAUD_NODE_TRAFFIC_MEDIAN_MULTIPLIER=4
# …or when a single user holds at least this share (%) of the top-users total.
ANTIFRAUD_NODE_TRAFFIC_SHARE_PERCENT=35
# Max connected nodes aggregated per run (bounds the panel call).
ANTIFRAUD_NODE_TRAFFIC_MAX_NODES=25
