// =============================================================================
//  rezeis-admin — Prisma Schema (rebuilt to match application code)
//
//  Conventions:
//    - All primary keys are CUIDs (string).
//    - Field names are camelCase, mapped to snake_case columns.
//    - Snapshots, settings, and ad-hoc payloads live in JSON columns.
//
//  Database: PostgreSQL  |  ORM: Prisma Client JS
// =============================================================================

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

