model User {
  id                             String    @id @default(cuid()) @map("id")
  telegramId                     BigInt?   @unique @map("telegram_id") @db.BigInt
  username                       String?   @map("username")
  email                          String?   @unique @map("email")
  referralCode                   String    @unique @default(cuid()) @map("referral_code")
  name                           String    @default("") @map("name")
  role                           UserRole  @default(USER) @map("role")
  language                       Locale    @default(EN) @map("language")
  personalDiscount               Int       @default(0) @map("personal_discount")
  purchaseDiscount               Int       @default(0) @map("purchase_discount")
  points                         Int       @default(0) @map("points")
  isBlocked                      Boolean   @default(false) @map("is_blocked")
  isBotBlocked                   Boolean   @default(false) @map("is_bot_blocked")
  isRulesAccepted                Boolean   @default(true) @map("is_rules_accepted")
  partnerBalanceCurrencyOverride Currency? @map("partner_balance_currency_override")
  /// Per-user override for referral invite limits. NULL means "use the
  /// global settings as-is". Otherwise, fields named after the global
  /// `Settings.referralSettings.invite_limits` keys override their
  /// respective values one-by-one (mirrors altshop's
  /// `ReferralInviteIndividualSettingsDto`).
  referralInviteSettings         Json?     @map("referral_invite_settings")
  /// Maximum number of concurrent active subscriptions per user.
  maxSubscriptions               Int       @default(1) @map("max_subscriptions")
  /// Optional pointer to the user's currently selected subscription.
  currentSubscriptionId          String?   @unique @map("current_subscription_id")
  createdAt                      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  // Relations
  subscriptions        Subscription[]          @relation("UserSubscriptions")
  currentSubscription  Subscription?           @relation("UserCurrentSubscription", fields: [currentSubscriptionId], references: [id], onDelete: SetNull)
  webAccount           WebAccount?             @relation("UserWebAccount")
  transactions         Transaction[]           @relation("UserTransactions")
  notificationEvents   UserNotificationEvent[] @relation("UserNotificationEvents")
  webPushSubscriptions WebPushSubscription[]   @relation("UserWebPushSubscriptions")
  trialGrant           TrialGrant?             @relation("UserTrialGrant")
  referredBy           Referral?               @relation("ReferredUser")
  referralsGiven       Referral[]              @relation("ReferrerUser")
  partner              Partner?                @relation("UserPartner")
  referralInvites      ReferralInvite[]        @relation("InviterUser")
  promocodeActivations PromocodeActivation[]   @relation("UserPromocodeActivations")
  referralRewards      ReferralReward[]        @relation("ReferralRewardUser")
  partnerTransactions  PartnerTransaction[]    @relation("PartnerTransactionReferral")
  partnerReferrals     PartnerReferral[]       @relation("PartnerReferralUser")
  supportTickets       SupportTicket[]         @relation("SupportTicketUser")

  @@index([telegramId])
  @@index([role])
  @@index([isBlocked])
  @@index([createdAt])
  @@map("users")
}

/// Single trial allocation per user — used as a hard guard so quote service
/// can answer `hasUsedTrial` without scanning subscription history.
model TrialGrant {
  id        String   @id @default(cuid()) @map("id")
  userId    String   @unique @map("user_id")
  planId    String?  @map("plan_id")
  grantedAt DateTime @default(now()) @map("granted_at") @db.Timestamptz(3)

  user User @relation("UserTrialGrant", fields: [userId], references: [id], onDelete: Cascade)

  @@map("trial_grants")
}

// =============================================================================
//  WEB ACCOUNTS & AUTH CHALLENGES
// =============================================================================

/// Linked web/credentials account that mirrors a Telegram user. Used by
/// `internal-user` flows when a user signs in by login + password.
model WebAccount {
  id                         String    @id @default(cuid()) @map("id")
  userId                     String    @unique @map("user_id")
  login                      String?   @unique @map("login")
  loginNormalized            String?   @unique @map("login_normalized")
  email                      String?   @unique @map("email")
  emailNormalized            String?   @unique @map("email_normalized")
  emailVerifiedAt            DateTime? @map("email_verified_at") @db.Timestamptz(3)
  passwordHash               String?   @map("password_hash")
  requiresPasswordChange     Boolean   @default(false) @map("requires_password_change")
  temporaryPasswordExpiresAt DateTime? @map("temporary_password_expires_at") @db.Timestamptz(3)
  /// Set when the user first enrolls credentials. Acts as an idempotency
  /// guard for `setWebAccountPassword`.
  credentialsBootstrappedAt  DateTime? @map("credentials_bootstrapped_at") @db.Timestamptz(3)
  /// When the user dismisses the link prompt.
  linkPromptSnoozeUntil      DateTime? @map("link_prompt_snooze_until") @db.Timestamptz(3)
  createdAt                  DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  user       User            @relation("UserWebAccount", fields: [userId], references: [id], onDelete: Cascade)
  challenges AuthChallenge[] @relation("WebAccountChallenges")

  @@map("web_accounts")
}

/// Time-limited verification challenges (email codes, magic links, etc.).
model AuthChallenge {
  id           String    @id @default(cuid()) @map("id")
  webAccountId String    @map("web_account_id")
  /// Logical purpose of the challenge: "email_verify", "password_reset", ...
  purpose      String    @map("purpose")
  /// Delivery channel: "email", "telegram", ...
  channel      String    @map("channel")
  /// Destination address for the challenge (email, telegram chat id, ...).
  destination  String    @map("destination")
  codeHash     String?   @map("code_hash")
  tokenHash    String?   @map("token_hash")
  attemptsLeft Int       @default(5) @map("attempts_left")
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz(3)
  consumedAt   DateTime? @map("consumed_at") @db.Timestamptz(3)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  webAccount WebAccount @relation("WebAccountChallenges", fields: [webAccountId], references: [id], onDelete: Cascade)

  @@index([webAccountId, purpose])
  @@index([destination, purpose])
  @@map("auth_challenges")
}

// =============================================================================
//  SUBSCRIPTIONS
// =============================================================================

model Subscription {
  id             String             @id @default(cuid()) @map("id")
  userId         String             @map("user_id")
  status         SubscriptionStatus @default(ACTIVE) @map("status")
  isTrial        Boolean            @default(false) @map("is_trial")
  /// Snapshot of the plan at purchase time (id, name, type, limits, ...).
  planSnapshot   Json               @default("{}") @map("plan_snapshot")
  trafficLimit   Int?               @map("traffic_limit")
  deviceLimit    Int                @default(0) @map("device_limit")
  internalSquads String[]           @default([]) @map("internal_squads")
  externalSquad  String?            @map("external_squad")
  /// Remnawave subscription user UUID. `null` until the profile sync job
  /// successfully creates the upstream record.
  remnawaveId    String?            @map("remnawave_id")
  /// User-facing connect URL.
  configUrl      String?            @map("config_url")
  startedAt      DateTime?          @map("started_at") @db.Timestamptz(3)
  expiresAt      DateTime?          @map("expires_at") @db.Timestamptz(3)
  deviceType     DeviceType?        @map("device_type")
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)

  user                  User                  @relation("UserSubscriptions", fields: [userId], references: [id], onDelete: Cascade)
  currentSubscriptionOf User?                 @relation("UserCurrentSubscription")
  transactions          Transaction[]         @relation("SubscriptionTransactions")
  syncJobs              ProfileSyncJob[]      @relation("SubscriptionSyncJobs")
  promocodeActivations  PromocodeActivation[] @relation("SubscriptionPromocodeActivations")

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
  @@index([isTrial])
  @@index([createdAt])
  @@map("subscriptions")
}

/// Background job describing the next Remnawave profile mutation for a
/// subscription. Materialized in the database so workers can resume after
/// restart.
model ProfileSyncJob {
  id             String        @id @default(cuid()) @map("id")
  subscriptionId String        @map("subscription_id")
  action         SyncAction    @map("action")
  status         SyncJobStatus @default(PENDING) @map("status")
  attempts       Int           @default(0) @map("attempts")
  lastError      String?       @map("last_error")
  payload        Json          @default("{}") @map("payload")
  scheduledAt    DateTime?     @map("scheduled_at") @db.Timestamptz(3)
  startedAt      DateTime?     @map("started_at") @db.Timestamptz(3)
  completedAt    DateTime?     @map("completed_at") @db.Timestamptz(3)
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)

  subscription Subscription @relation("SubscriptionSyncJobs", fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([status])
  @@index([action])
  @@map("profile_sync_jobs")
}

