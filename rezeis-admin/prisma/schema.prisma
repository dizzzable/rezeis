/// Partner balance ledger. One record per user.
model Partner {
  id             String   @id @default(cuid()) @map("id")
  userId         String   @unique @map("user_id")
  /// Balance stored in minor units (cents/kopecks) for integer precision.
  balance        Int      @default(0) @map("balance")
  totalEarned    Int      @default(0) @map("total_earned")
  totalWithdrawn Int      @default(0) @map("total_withdrawn")
  isActive       Boolean  @default(true) @map("is_active")

  /// Whether this partner uses the global partner settings (`Settings.partnerSettings`)
  /// or its own per-user override defined by the columns below.
  /// Donor: altshop `partner.individual_settings.use_global_settings`.
  useGlobalSettings Boolean              @default(true) @map("use_global_settings")
  accrualStrategy   PartnerAccrualStrategy @default(ON_EACH_PAYMENT) @map("accrual_strategy")
  rewardType        PartnerRewardType      @default(PERCENT) @map("reward_type")

  /// Per-level percentages used when `rewardType = PERCENT` and
  /// `useGlobalSettings = false`. NULL falls back to the global value.
  /// Stored as numeric(5,2) to match `partner_transactions.percent`.
  level1Percent     Decimal? @map("level1_percent") @db.Decimal(5, 2)
  level2Percent     Decimal? @map("level2_percent") @db.Decimal(5, 2)
  level3Percent     Decimal? @map("level3_percent") @db.Decimal(5, 2)

  /// Per-level fixed amounts (in minor units) used when
  /// `rewardType = FIXED` and `useGlobalSettings = false`.
  level1FixedAmount Int?     @map("level1_fixed_amount")
  level2FixedAmount Int?     @map("level2_fixed_amount")
  level3FixedAmount Int?     @map("level3_fixed_amount")

  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  user         User                 @relation("UserPartner", fields: [userId], references: [id], onDelete: Cascade)
  withdrawals  PartnerWithdrawal[]  @relation("PartnerWithdrawals")
  transactions PartnerTransaction[] @relation("PartnerLedgerTransactions")
  referrals    PartnerReferral[]    @relation("PartnerReferralPartner")

  @@index([userId])
  @@index([isActive])
  @@map("partners")
}

/// Partner withdrawal request lifecycle.
model PartnerWithdrawal {
  id           String           @id @default(cuid()) @map("id")
  partnerId    String           @map("partner_id")
  /// Amount in minor units (matches `Partner.balance`).
  amount       Int              @map("amount")
  status       WithdrawalStatus @default(PENDING) @map("status")
  /// Free-form payout method label, e.g. `card`, `tron-usdt`, ...
  method       String           @map("method")
  requisites   String           @map("requisites")
  adminComment String?          @map("admin_comment")
  /// Admin user id (cuid) that processed this withdrawal.
  processedBy  String?          @map("processed_by")
  processedAt  DateTime?        @map("processed_at") @db.Timestamptz(3)
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)

  partner Partner @relation("PartnerWithdrawals", fields: [partnerId], references: [id], onDelete: Restrict)

  @@index([partnerId])
  @@index([status])
  @@index([createdAt])
  @@map("partner_withdrawals")
}

// =============================================================================
//  BROADCASTS
// =============================================================================

model Broadcast {
  id             String            @id @default(cuid()) @map("id")
  status         BroadcastStatus   @default(DRAFT) @map("status")
  audience       BroadcastAudience @default(ALL) @map("audience")
  /// Optional plan id used by audience filters that need a plan reference.
  audiencePlanId String?           @map("audience_plan_id")
  /// JSON: { text, mediaType, mediaFileId, parseMode, ... }
  payload        Json              @default("{}") @map("payload")
  totalCount     Int               @default(0) @map("total_count")
  successCount   Int               @default(0) @map("success_count")
  failedCount    Int               @default(0) @map("failed_count")
  /// Admin user id (cuid) who created the draft.
  createdBy      String?           @map("created_by")
  startedAt      DateTime?         @map("started_at") @db.Timestamptz(3)
  completedAt    DateTime?         @map("completed_at") @db.Timestamptz(3)
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime          @updatedAt @map("updated_at") @db.Timestamptz(3)

  messages BroadcastMessage[]

  @@index([status])
  @@index([audience])
  @@index([createdAt])
  @@map("broadcasts")
}

model BroadcastMessage {
  id                String                 @id @default(cuid()) @map("id")
  broadcastId       String                 @map("broadcast_id")
  userId            String                 @map("user_id")
  /// Telegram message_id once sent (nullable until delivery is attempted).
  telegramMessageId BigInt?                @map("telegram_message_id") @db.BigInt
  status            BroadcastMessageStatus @default(PENDING) @map("status")
  errorMessage      String?                @map("error_message")
  sentAt            DateTime?              @map("sent_at") @db.Timestamptz(3)
  createdAt         DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime               @updatedAt @map("updated_at") @db.Timestamptz(3)

  broadcast Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  @@index([broadcastId])
  @@index([userId])
  @@index([status])
  @@map("broadcast_messages")
}

// =============================================================================
//  NOTIFICATIONS & SETTINGS
// =============================================================================

model UserNotificationEvent {
  id        String    @id @default(cuid()) @map("id")
  userId    String    @map("user_id")
  type      String    @map("type")
  payload   Json      @default("{}") @map("payload")
  readAt    DateTime? @map("read_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation("UserNotificationEvents", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([readAt])
  @@index([createdAt])
  @@map("user_notification_events")
}

/// Web-push subscription for browser-based notifications. One row per
/// (user, endpoint) tuple — a single user can register multiple
/// subscriptions (laptop + phone PWA) and each one delivers
/// independently.
///
/// Storage shape mirrors the W3C Push API spec: the `endpoint` URL
/// identifies the push service (FCM / Mozilla / Apple); `p256dhKey`
/// + `authKey` are the per-subscription crypto material the spec
/// requires for end-to-end encryption.
///
/// `failureCount` increments on transient delivery failures; the
/// fanout service deletes the row after 3 consecutive failures or
/// on any 410 Gone response from the push service. `lastSeenAt` is
/// touched on every successful delivery so operators can tell which
/// subscriptions are stale.
model WebPushSubscription {
  id           String   @id @default(cuid()) @map("id")
  userId       String   @map("user_id")
  endpoint     String   @unique @map("endpoint")
  p256dhKey    String   @map("p256dh_key")
  authKey      String   @map("auth_key")
  userAgent    String?  @map("user_agent")
  failureCount Int      @default(0) @map("failure_count")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  lastSeenAt   DateTime @default(now()) @map("last_seen_at") @db.Timestamptz(3)

  user User @relation("UserWebPushSubscriptions", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("web_push_subscriptions")
}

/// Broadcast destination for SystemEvent-driven notifications. Each
/// row is a Telegram chat (group / channel) the admin wants the bot
/// to forward operator-relevant events to. `topicThreadId` is set
/// when the destination is a forum topic — Telegram's
/// `message_thread_id` API lets us address a specific topic inside a
/// supergroup with topics enabled. `kindFilter` restricts which event
/// types reach this destination (empty array means "all events").
///
/// Multiple rows can target the same chat with different filters
/// (e.g. one row for `subscription.*` events into the support topic,
/// another for `partner.*` events into the partner topic).
model BotNotificationChannel {
  id            String   @id @default(cuid()) @map("id")
  /// Operator-supplied label shown in the admin UI ("Admin events",
  /// "Partners channel", etc.). Not sent to Telegram.
  name          String   @map("name")
  /// Telegram chat id. Numeric (-100xxxxxxxxx for channels /
  /// supergroups, -xxx for normal groups, +xxx for users which we
  /// don't expect operators to use here). Stored as string so we
  /// don't have to deal with bigint serialisation on the wire.
  chatId        String   @map("chat_id")
  /// Forum topic thread id when the destination is a topic. `null`
  /// for a regular chat / channel.
  topicThreadId Int?     @map("topic_thread_id")
  /// SystemEvent type strings this destination accepts. Empty array
  /// means "no filter" (every event the fanout service decides to
  /// broadcast). Concrete patterns the operator types — exact match,
  /// no globs (yet); the fanout layer keeps that surface predictable.
  kindFilter    String[] @default([]) @map("kind_filter")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([isActive])
  @@map("bot_notification_channels")
}

/// Singleton row (id = 1).
model Settings {
  id                        Int        @id @default(1) @map("id")
  rulesRequired             Boolean    @default(false) @map("rules_required")
  channelRequired           Boolean    @default(false) @map("channel_required")
  rulesLink                 String     @default("") @map("rules_link")
  channelId                 BigInt?    @map("channel_id") @db.BigInt
  channelLink               String     @default("") @map("channel_link")
  accessMode                AccessMode @default(PUBLIC) @map("access_mode")
  inviteModeStartedAt       DateTime?  @map("invite_mode_started_at") @db.Timestamptz(3)
  defaultCurrency           Currency   @default(RUB) @map("default_currency")
  paymentOpsAlerts          Json       @default("{}") @map("payment_ops_alerts")
  systemNotifications       Json       @default("{}") @map("system_notifications")
  platformPolicy            Json       @default("{}") @map("platform_policy")
  /// User-facing notification preferences (donor: settings.user_notifications JSON).
  userNotifications         Json       @default("{}") @map("user_notifications")
  /// Referral program tunables (donor: settings.referral_settings JSON).
  referralSettings          Json       @default("{}") @map("referral_settings")
  /// Partner program tunables (donor: settings.partner_settings JSON).
  partnerSettings           Json       @default("{}") @map("partner_settings")
  /// Multi-subscription policy (donor: settings.multi_subscription_settings JSON).
  multiSubscriptionSettings Json       @default("{}") @map("multi_subscription_settings")
  /// Branding settings (donor: settings.branding_settings JSON).
  brandingSettings          Json       @default("{}") @map("branding_settings")
  /// Bot menu visual settings (donor: settings.bot_menu_settings JSON).
  botMenuSettings           Json       @default("{}") @map("bot_menu_settings")
  updatedAt                 DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("settings")
}

// =============================================================================
//  API TOKENS
// =============================================================================

/// Named API tokens for external service integration (reiwa, bots, etc.).
/// Each token is a signed JWT that can be verified without DB lookup on hot
/// path, but the row must exist for the token to remain valid (revocation =
/// delete the row).
model ApiToken {
  id         String    @id @default(cuid()) @map("id")
  /// Human-readable label, e.g. "RezeisBot", "Reiwa", "Subpage".
  name       String    @map("name")
  /// The signed JWT string. Stored so the admin can copy it from the UI.
  token      String    @unique @map("token")
  /// Short prefix shown in listings (first 8 chars of token for identification).
  prefix     String    @map("prefix")
  /// Admin who created this token.
  createdBy  String?   @map("created_by")
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz(3)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([name])
  @@index([createdAt])
  @@map("api_tokens")
}

// =============================================================================
//  PROMOCODES
// =============================================================================

/// Promotional code reference (donor: altshop `Promocode`).
///
/// `plan` is a JSON snapshot used by the SUBSCRIPTION reward type — it stores
/// the plan id, name, type, traffic/device limits and `duration` (days) at
/// the moment the promo was created. We keep the snapshot inside the row to
/// preserve historical activations even if the plan catalog is later
/// reshaped.
model Promocode {
  id                 String                @id @default(cuid()) @map("id")
  code               String                @unique @map("code")
  isActive           Boolean               @default(true) @map("is_active")
  availability       PromocodeAvailability @default(ALL) @map("availability")
  rewardType         PromocodeRewardType   @map("reward_type")
  /// Reward magnitude. The semantics depend on `rewardType`:
  ///  - DURATION → days
  ///  - TRAFFIC  → GB
  ///  - DEVICES  → device slots
  ///  - PERSONAL_DISCOUNT / PURCHASE_DISCOUNT → percent (0-100)
  ///  - SUBSCRIPTION → optional fallback duration (also stored in `plan`)
  reward             Int?                  @map("reward")
  /// JSON: { id, name, type, trafficLimit, deviceLimit, duration, ... }.
  /// Required when `rewardType = SUBSCRIPTION`.
  plan               Json?                 @map("plan")
  /// Days until the code expires. `-1` (or null) = unlimited.
  lifetime           Int?                  @map("lifetime")
  /// Maximum number of total activations. `-1` (or null) = unlimited.
  maxActivations     Int?                  @map("max_activations")
  /// Optional allow-list of telegram_ids (donor compatibility — keep as text
  /// to avoid coupling to a specific id type).
  allowedTelegramIds BigInt[]              @default([]) @map("allowed_telegram_ids")
  /// Optional allow-list of plan ids — promo only applies if the target
  /// subscription is on one of these plans.
  allowedPlanIds     String[]              @default([]) @map("allowed_plan_ids")
  createdAt          DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)

  activations PromocodeActivation[]

  @@index([isActive])
  @@index([availability])
  @@index([rewardType])
  @@index([createdAt])
  @@map("promocodes")
}

/// One activation record per (promocode, user). The `(promocodeId, userId)`
/// pair is unique — promos are single-use per user.
model PromocodeActivation {
  id                   String              @id @default(cuid()) @map("id")
  promocodeId          String              @map("promocode_id")
  userId               String              @map("user_id")
  /// Snapshot of `Promocode.code` at activation time (donor parity).
  promocodeCode        String              @map("promocode_code")
  /// Snapshot of `Promocode.rewardType` at activation time.
  rewardType           PromocodeRewardType @map("reward_type")
  /// Resolved reward magnitude actually applied (may differ from
  /// `Promocode.reward` for SUBSCRIPTION fallbacks that read `plan.duration`).
  rewardValue          Int                 @default(0) @map("reward_value")
  targetSubscriptionId String?             @map("target_subscription_id")
  activatedAt          DateTime            @default(now()) @map("activated_at") @db.Timestamptz(3)

  promocode          Promocode     @relation(fields: [promocodeId], references: [id], onDelete: Restrict)
  user               User          @relation("UserPromocodeActivations", fields: [userId], references: [id], onDelete: Restrict)
  targetSubscription Subscription? @relation("SubscriptionPromocodeActivations", fields: [targetSubscriptionId], references: [id], onDelete: SetNull)

  @@unique([promocodeId, userId])
  @@index([promocodeId])
  @@index([userId])
  @@index([rewardType])
  @@index([activatedAt])
  @@map("promocode_activations")
}

// =============================================================================
//  REFERRAL REWARDS, PARTNER LEDGER
// =============================================================================

/// Reward emitted when a `Referral` qualifies. Multiple rewards can attach to
/// a single referral edge — donor distinguishes points and extra-day rewards.
model ReferralReward {
  id           String             @id @default(cuid()) @map("id")
  referralId   String             @map("referral_id")
  userId       String             @map("user_id")
  type         ReferralRewardType @map("type")
  amount       Int                @map("amount")
  isIssued     Boolean            @default(false) @map("is_issued")
  issuedAt     DateTime?          @map("issued_at") @db.Timestamptz(3)
  /// Admin user id (cuid) that triggered the issue. NULL for legacy
  /// rows or rewards issued by the auto-issue cron.
  issuedBy     String?            @map("issued_by")
  /// Admin user id (cuid) that manually granted this reward via the
  /// "Issue reward" dialog. NULL for rewards created automatically by
  /// `ReferralQualificationService` after a qualifying purchase.
  grantedBy    String?            @map("granted_by")
  /// Set when an admin (or the refund handler) revokes a pending or
  /// issued reward. We keep the row for audit but stop counting it
  /// in stats.
  revokedAt    DateTime?          @map("revoked_at") @db.Timestamptz(3)
  revokeReason String?            @map("revoke_reason")
  createdAt    DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)

  referral Referral @relation("ReferralRewardEdge", fields: [referralId], references: [id], onDelete: Cascade)
  user     User     @relation("ReferralRewardUser", fields: [userId], references: [id], onDelete: Restrict)

  @@index([referralId])
  @@index([userId])
  @@index([isIssued])
  @@index([issuedBy])
  @@index([grantedBy])
  @@index([revokedAt])
  @@map("referral_rewards")
}

/// Partner ledger entry — accrual or correction. Amounts are in minor units
/// matching `Partner.balance`. The donor stores both per-payment accruals
/// and admin-side adjustments here; we keep the `description` free-form so
/// the same table can absorb future ledger kinds without a new enum.
model PartnerTransaction {
  id                  String   @id @default(cuid()) @map("id")
  partnerId           String   @map("partner_id")
  /// User the accrual is attributed to (donor field name preserved).
  referralUserId      String   @map("referral_user_id")
  level               Int      @map("level")
  paymentAmount       Int      @map("payment_amount")
  /// Accrual percent (0-100, 2 decimals) — donor compatibility.
  percent             Decimal  @map("percent") @db.Decimal(5, 2)
  earnedAmount        Int      @map("earned_amount")
  sourceTransactionId String?  @map("source_transaction_id")
  description         String?  @map("description")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  partner  Partner @relation("PartnerLedgerTransactions", fields: [partnerId], references: [id], onDelete: Cascade)
  referral User    @relation("PartnerTransactionReferral", fields: [referralUserId], references: [id], onDelete: Cascade)

  @@index([partnerId])
  @@index([referralUserId])
  @@index([level])
  @@index([createdAt])
  @@map("partner_transactions")
}

/// Partner referral graph — one edge per (partner, referral). The donor
/// duplicates this edge from the regular `Referral` table because the
/// partner program runs its own ledger and accounting. Keep them separate.
model PartnerReferral {
  id              String   @id @default(cuid()) @map("id")
  partnerId       String   @map("partner_id")
  referralUserId  String   @map("referral_user_id")
  level           Int      @map("level")
  parentPartnerId String?  @map("parent_partner_id")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  partner  Partner @relation("PartnerReferralPartner", fields: [partnerId], references: [id], onDelete: Cascade)
  referral User    @relation("PartnerReferralUser", fields: [referralUserId], references: [id], onDelete: Cascade)

  @@unique([partnerId, referralUserId])
  @@index([partnerId])
  @@index([referralUserId])
  @@index([parentPartnerId])
  @@index([level])
  @@map("partner_referrals")
}

// =============================================================================
//  OPERATIONS — backups, imports, support
// =============================================================================

model BackupRecord {
  id                String      @id @default(cuid()) @map("id")
  filename          String      @map("filename")
  scope             BackupScope @map("scope")
  /// Size in bytes.
  sizeBytes         BigInt      @map("size_bytes") @db.BigInt
  checksum          String?     @map("checksum")
  /// Delivery channel: "local" | "telegram" | "s3" | ...
  deliveryChannel   String      @map("delivery_channel")
  deliveryRecipient String?     @map("delivery_recipient")
  deliveredAt       DateTime?   @map("delivered_at") @db.Timestamptz(3)
  errorMessage      String?     @map("error_message")
  createdAt         DateTime    @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([scope])
  @@index([deliveryChannel])
  @@index([createdAt])
  @@map("backup_records")
}

model ImportRecord {
  id            String       @id @default(cuid()) @map("id")
  filename      String       @map("filename")
  /// Source format identifier: "3xui" | "remnawave" | "marzban" | ...
  sourceType    String       @map("source_type")
  status        ImportStatus @default(DRAFT) @map("status")
  recordsTotal  Int          @default(0) @map("records_total")
  recordsOk     Int          @default(0) @map("records_ok")
  recordsFailed Int          @default(0) @map("records_failed")
  /// JSON: dry-run diff / committed entity ids / rollback plan.
  result        Json?        @map("result")
  errorMessage  String?      @map("error_message")
  /// Admin user id (cuid) who initiated the import.
  createdBy     String?      @map("created_by")
  committedAt   DateTime?    @map("committed_at") @db.Timestamptz(3)
  rolledBackAt  DateTime?    @map("rolled_back_at") @db.Timestamptz(3)
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([sourceType])
  @@index([status])
  @@index([createdAt])
  @@map("import_records")
}

/// Editable templates per notification event type. Used by the worker that
/// actually renders and dispatches notifications.
model NotificationTemplate {
  id        String   @id @default(cuid()) @map("id")
  type      String   @unique @map("type")
  /// Title template (Handlebars-style placeholders).
  title     String   @map("title")
  /// Body template.
  body      String   @map("body")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([isActive])
  @@map("notification_templates")
}

model SupportTicket {
  id        String              @id @default(cuid()) @map("id")
  userId    String              @map("user_id")
  subject   String              @map("subject")
  status    SupportTicketStatus @default(OPEN) @map("status")
  closedAt  DateTime?           @map("closed_at") @db.Timestamptz(3)
  closedBy  String?             @map("closed_by")
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)

  user     User                   @relation("SupportTicketUser", fields: [userId], references: [id], onDelete: Cascade)
  messages SupportTicketMessage[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("support_tickets")
}

model SupportTicketMessage {
  id         String                  @id @default(cuid()) @map("id")
  ticketId   String                  @map("ticket_id")
  authorType SupportTicketAuthorType @map("author_type")
  /// Admin user id (when authorType = ADMIN) or end-user id (when USER).
  authorId   String?                 @map("author_id")
  content    String                  @map("content")
  createdAt  DateTime                @default(now()) @map("created_at") @db.Timestamptz(3)

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([createdAt])
  @@map("support_ticket_messages")
}

// =============================================================================
//  FAQ
// =============================================================================

/// FAQ item managed by admins, displayed to users in the Help section.
model FaqItem {
  id         String   @id @default(cuid()) @map("id")
  question   String   @map("question")
  answer     String   @map("answer")
  /// Optional ordered list of media URLs (image/video) attached to the
  /// answer. URLs are relative to the admin host
  /// (`/uploads/faq/<filename>`) when the file was uploaded through the
  /// admin panel; absolute URLs are also accepted for externally hosted
  /// assets.
  mediaUrls  String[] @default([]) @map("media_urls")
  /// Display order (lower = higher in the list).
  orderIndex Int      @default(0) @map("order_index")
  isActive   Boolean  @default(true) @map("is_active")
  /// Locale code (e.g. "ru", "en"). Null = shown for all locales.
  locale     String?  @map("locale")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([isActive, orderIndex])
  @@index([locale])
  @@map("faq_items")
}

// =============================================================================
//  ADD-ONS (extra services: traffic, devices)
// =============================================================================

enum AddOnType {
  EXTRA_TRAFFIC
  EXTRA_DEVICES
}

/// Purchasable add-on that extends an active subscription's limits.
/// Add-ons are created by the admin and optionally restricted to specific plans.
///
/// Example: "+50 GB Traffic" (EXTRA_TRAFFIC, value=50, price per currency).
/// When no `applicablePlanIds` are set, the add-on is available for ALL plans.
model AddOn {
  id                String    @id @default(cuid()) @map("id")
  name              String    @map("name")
  description       String?   @map("description")
  type              AddOnType @map("type")
  /// Magnitude of the add-on:
  ///   - EXTRA_TRAFFIC → GB to add
  ///   - EXTRA_DEVICES → device slots to add
  value             Int       @map("value")
  isActive          Boolean   @default(true) @map("is_active")
  orderIndex        Int       @default(0) @map("order_index")
  /// Plan IDs this add-on applies to. Empty = available for all plans.
  applicablePlanIds String[]  @default([]) @map("applicable_plan_ids")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  prices AddOnPrice[]

  @@index([isActive, orderIndex])
  @@index([type])
  @@map("add_ons")
}

/// Per-currency pricing for an add-on.
model AddOnPrice {
  id       String   @id @default(cuid()) @map("id")
  addOnId  String   @map("add_on_id")
  currency Currency @map("currency")
  price    Decimal  @map("price") @db.Decimal(20, 8)

  addOn AddOn @relation(fields: [addOnId], references: [id], onDelete: Cascade)

  @@unique([addOnId, currency])
  @@map("add_on_prices")
}

// =============================================================================
//  BOT CONFIG (rezeis bot menu, premium emoji, copy)
// =============================================================================

/// Visual style applied to a bot menu button. Drives icon colour and the
/// hint text shown under the button on Telegram clients that support
/// inline reply-keyboard styling.
enum BotButtonStyle {
  PRIMARY
  SUCCESS
  DANGER
  DEFAULT
}

/// What happens when a user taps a reply-keyboard button.
enum BotButtonAction {
  /// Emit `callback_data === buttonId` and let reiwa's
  /// `bot.callbackQuery(id, ...)` handler resolve the response.
  /// Default for back-compat with existing reserved ids
  /// (cabinet / invite / rules / help) and any operator-defined
  /// id whose target hasn't been set yet.
  CALLBACK
  /// Open an external HTTPS URL in Telegram's in-app browser.
  /// `actionTarget` holds the absolute URL.
  URL
  /// Open a Telegram Mini App. `actionTarget` holds the absolute
  /// HTTPS URL (Telegram refuses non-HTTPS web_app buttons).
  WEBAPP
  /// Render a dynamic screen by `BotFlowScreen.shortId`. Goes through
  /// the same `screen:<shortId>` callback the universal screen
  /// renderer in reiwa already handles.
  SCREEN
  /// Open a `t.me/<handle>?text=<prefill>` deep-link to a support
  /// chat. `actionTarget` is unused — reiwa resolves the handle
  /// from `BOT_SUPPORT_USERNAME` or admin override at render time.
  SUPPORT_URL
}

/// One row per button rendered in the bot's main reply keyboard. Operators
/// reorder, hide, restyle, or attach a Telegram Premium emoji directly
/// from the admin panel; the bot service reads the latest snapshot and
/// rebuilds keyboards accordingly.
model BotButton {
  id                 String          @id @default(cuid()) @map("id")
  /// Stable button identifier the bot service uses when wiring up
  /// callbacks, e.g. `subscriptions`, `support`, `referrals`. Slug is
  /// case-insensitive and must be unique.
  buttonId           String          @unique @map("button_id")
  label              String          @map("label")
  /// Display style — see `BotButtonStyle`.
  style              BotButtonStyle  @default(PRIMARY) @map("style")
  /// Optional Telegram Premium custom emoji id (string). Non-premium
  /// users see a fallback emoji rendered by the bot side.
  iconCustomEmojiId  String?         @map("icon_custom_emoji_id")
  /// Soft-delete-style visibility flag. Hidden buttons are not rendered
  /// but remain in the catalog so settings can be restored.
  visible            Boolean         @default(true) @map("visible")
  /// When `true`, the button claims the entire row regardless of its
  /// natural width. Otherwise it shares a row with the next half-width
  /// neighbour.
  onePerRow          Boolean         @default(false) @map("one_per_row")
  /// Render order — lower values come first inside the keyboard.
  orderIndex         Int             @default(0) @map("order_index")
  /// What the button does when tapped. See `BotButtonAction`.
  /// Defaults to CALLBACK so existing rows light up the legacy
  /// callback-based handlers (cabinet/invite/rules/help) without a
  /// data migration.
  actionType         BotButtonAction @default(CALLBACK) @map("action_type")
  /// Action payload — interpretation depends on `actionType`:
  ///   - URL / WEBAPP   → absolute URL
  ///   - SCREEN         → `BotFlowScreen.shortId`
  ///   - CALLBACK / SUPPORT_URL → unused (kept null)
  /// Validation lives at the service layer (URL parsing, shortId
  /// existence check) so the schema stays simple.
  actionTarget       String?         @map("action_target")
  createdAt          DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime        @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([visible, orderIndex])
  @@map("bot_buttons")
}

/// Editable emoji catalog. Each row is a single key (`STAR`, `CHECK`, …)
/// with a Unicode fallback and an optional Telegram Premium custom emoji.
model BotEmoji {
  id         String   @id @default(cuid()) @map("id")
  /// Upper-case slug used by the bot when rendering text:
  /// `{{emoji.STAR}}`. Unique per row.
  key        String   @unique @map("key")
  /// Default Unicode codepoint shown to non-Premium users.
  unicode    String   @map("unicode")
  /// Telegram Premium animated/custom emoji id (string).
  tgEmojiId  String?  @map("tg_emoji_id")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("bot_emojis")
}

/// Editable copy snippets used by the bot. Operators tweak welcome
/// messages, callbacks, error strings without redeploying the bot.
model BotText {
  id        String   @id @default(cuid()) @map("id")
  /// Lookup key (`welcome.greeting`, `support.intro`, …). Unique per row.
  key       String   @unique @map("key")
  value     String   @map("value")
  /// Hidden snippets are not served by the bot; useful when staging a
  /// rewrite before activation.
  visible   Boolean  @default(true) @map("visible")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([visible])
  @@map("bot_texts")
}

// =============================================================================
//  BOT FLOW EDITOR — Visual navigation graph for Telegram inline keyboards
// =============================================================================

/// Status of a bot flow version.
enum BotFlowStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

/// Action type for a flow button.
enum BotFlowButtonAction {
  NAVIGATE     // Go to another screen in the flow
  URL          // Open external URL
  WEBAPP       // Open Telegram Mini App
  CALLBACK     // Trigger a built-in action (e.g. "show_subscription")
  BACK         // Navigate back in history
  START_OVER   // Return to root screen
}

/// Style for a flow button (maps to Telegram Bot API `style` field).
enum BotFlowButtonStyle {
  PRIMARY
  SUCCESS
  DANGER
  DEFAULT
}

/// Parse mode for screen message text.
enum BotFlowParseMode {
  HTML
  MARKDOWN
  PLAIN
}

/// Media type attached to a screen.
enum BotFlowMediaType {
  PHOTO
  VIDEO
  DOCUMENT
  ANIMATION
}

/// A versioned bot navigation flow. Operators design flows in the visual
/// editor; the bot runtime reads the latest PUBLISHED version.
model BotFlow {
  id          String        @id @default(cuid()) @map("id")
  /// Human-readable name for the flow (e.g. "Main Menu", "Onboarding").
  name        String        @default("Main Flow") @map("name")
  /// Auto-incrementing version number within this flow lineage.
  version     Int           @default(1) @map("version")
  /// Draft → Published → Archived lifecycle.
  status      BotFlowStatus @default(DRAFT) @map("status")
  /// React Flow viewport + global layout metadata (JSON).
  layoutData  Json?         @map("layout_data")
  /// When this version was published (null for drafts).
  publishedAt DateTime?     @map("published_at") @db.Timestamptz(3)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)

  screens     BotFlowScreen[]

  @@unique([name, version])
  @@index([status])
  @@map("bot_flows")
}

/// A single screen (node) in the flow graph. Represents one Telegram message
/// with optional media and an inline keyboard.
model BotFlowScreen {
  id          String             @id @default(cuid()) @map("id")
  /// Short ID used in callback_data (8 chars, fits in 64-byte limit).
  shortId     String             @map("short_id")
  flowId      String             @map("flow_id")
  flow        BotFlow            @relation(fields: [flowId], references: [id], onDelete: Cascade)

  /// Internal label for the editor (not shown to users).
  name        String             @default("New Screen") @map("name")
  /// Message text sent to the user — Russian.
  textRu      String             @default("") @map("text_ru") @db.Text
  /// Message text sent to the user — English.
  textEn      String             @default("") @map("text_en") @db.Text
  /// Parse mode for the message text.
  parseMode   BotFlowParseMode   @default(HTML) @map("parse_mode")
  /// Optional media attachment.
  mediaType   BotFlowMediaType?  @map("media_type")
  /// Telegram file_id for the media (used when sending).
  mediaFileId String?            @map("media_file_id")
  /// Preview URL for the editor (WebP thumbnail or direct URL).
  mediaUrl    String?            @map("media_url")

  /// Position on the React Flow canvas.
  positionX   Float              @default(0) @map("position_x")
  positionY   Float              @default(0) @map("position_y")
  /// Whether this is the entry point of the flow.
  isRoot      Boolean            @default(false) @map("is_root")

  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)

  buttons     BotFlowButton[]

  @@unique([flowId, shortId])
  @@index([flowId])
  @@map("bot_flow_screens")
}

/// A button in a flow screen's inline keyboard. Buttons with action=NAVIGATE
/// define edges in the graph (targetScreenId points to another screen).
model BotFlowButton {
  id                String              @id @default(cuid()) @map("id")
  screenId          String              @map("screen_id")
  screen            BotFlowScreen       @relation(fields: [screenId], references: [id], onDelete: Cascade)

  /// Button label text shown to the user — Russian.
  labelRu           String              @default("Кнопка") @map("label_ru")
  /// Button label text shown to the user — English.
  labelEn           String              @default("Button") @map("label_en")
  /// Row index (0-based) for inline keyboard layout.
  row               Int                 @default(0) @map("row")
  /// Column index within the row.
  col               Int                 @default(0) @map("col")

  /// What happens when the user presses this button.
  actionType        BotFlowButtonAction @map("action_type")
  /// For NAVIGATE: shortId of the target screen.
  targetScreenId    String?             @map("target_screen_id")
  /// For URL: external URL to open.
  url               String?             @map("url")
  /// For WEBAPP: Telegram Mini App URL.
  webAppUrl         String?             @map("web_app_url")
  /// For CALLBACK: built-in action identifier (e.g. "show_subscription").
  callbackAction    String?             @map("callback_action")

  /// Visual style (maps to Telegram Bot API `style` field).
  style             BotFlowButtonStyle  @default(DEFAULT) @map("style")
  /// Optional Telegram Premium custom emoji ID shown before the label.
  iconCustomEmojiId String?             @map("icon_custom_emoji_id")

  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([screenId])
  @@map("bot_flow_buttons")
}

// =============================================================================
//  REMNAWAVE METRICS & WEBHOOKS
// =============================================================================

/// Time-series samples collected from the Remnawave panel every 5 minutes.
/// Powers the online trends chart and per-node traffic history on the dashboard.
model RemnawaveMetricSample {
  id              String   @id @default(cuid()) @map("id")
  /// Total users online at sample time.
  onlineNow       Int      @map("online_now")
  /// Total registered users on the panel.
  totalUsers      Int      @map("total_users")
  /// Number of nodes currently online.
  nodesOnline     Int      @map("nodes_online")
  /// Total bandwidth consumed (bytes) across all nodes at sample time.
  totalBytesLifetime BigInt @map("total_bytes_lifetime")
  /// Per-node snapshot: JSON array of { uuid, name, usersOnline, trafficUsedBytes, isConnected }.
  nodesSnapshot   Json     @default("[]") @map("nodes_snapshot")
  /// Panel CPU cores count.
  cpuCores        Int      @default(0) @map("cpu_cores")
  /// Panel memory used (bytes).
  memoryUsed      BigInt   @default(0) @map("memory_used")
  /// Panel memory total (bytes).
  memoryTotal     BigInt   @default(0) @map("memory_total")
  /// Panel uptime in seconds.
  uptime          Int      @default(0) @map("uptime")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([createdAt])
  @@map("remnawave_metric_samples")
}

/// Webhook events received from the Remnawave panel.
/// Stored for the Activity Feed and audit trail.
model RemnawaveWebhookEvent {
  id          String   @id @default(cuid()) @map("id")
  /// Event type from the panel (e.g. "user.created", "user.updated", "node.offline").
  eventType   String   @map("event_type")
  /// Raw payload from the webhook (sanitized — no secrets).
  payload     Json     @default("{}") @map("payload")
  /// Whether this event has been processed/displayed.
  isProcessed Boolean  @default(false) @map("is_processed")
  /// Source IP of the webhook request.
  sourceIp    String?  @map("source_ip")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([eventType])
  @@index([isProcessed])
  @@index([createdAt])
  @@map("remnawave_webhook_events")
}

// =============================================================================
//  OAUTH2 PROVIDERS & PASSKEYS
// =============================================================================

/// Supported OAuth2/SSO provider types.
enum AuthProviderType {
  TELEGRAM
  GITHUB
  YANDEX
  KEYCLOAK
  POCKETID
  GENERIC_OAUTH2
}

/// Configuration for an OAuth2/SSO authentication provider.
/// Each row represents one configured provider (e.g. GitHub, Telegram).
/// Secrets are stored AES-256-GCM encrypted (same key as TOTP secrets).
model AuthProviderConfig {
  id              String           @id @default(cuid()) @map("id")
  type            AuthProviderType @unique @map("type")
  /// Whether this provider is currently enabled for login.
  isEnabled       Boolean          @default(false) @map("is_enabled")
  /// Display name shown on the login page button.
  displayName     String           @map("display_name")
  /// OAuth2 Client ID from the provider.
  clientId        String?          @map("client_id")
  /// OAuth2 Client Secret (AES-256-GCM encrypted).
  clientSecretEnc String?          @map("client_secret_enc")
  /// Frontend domain (without protocol) for redirect URIs.
  frontendDomain  String?          @map("frontend_domain")
  /// Backend domain (full URL) for callback endpoints.
  backendDomain   String?          @map("backend_domain")
  /// Provider-specific: Authorization URL (Generic OAuth2).
  authorizationUrl String?         @map("authorization_url")
  /// Provider-specific: Token URL (Generic OAuth2).
  tokenUrl        String?          @map("token_url")
  /// Provider-specific: Keycloak realm name.
  realm           String?          @map("realm")
  /// Provider-specific: Keycloak/PocketID domain.
  providerDomain  String?          @map("provider_domain")
  /// Whether to use PKCE (Generic OAuth2).
  usePkce         Boolean          @default(false) @map("use_pkce")
  /// Whitelist of allowed email addresses (empty = allow all).
  allowedEmails   String[]         @default([]) @map("allowed_emails")
  /// Whitelist of allowed Telegram IDs (Telegram provider only).
  allowedTelegramIds BigInt[]      @default([]) @map("allowed_telegram_ids")
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([isEnabled])
  @@map("auth_provider_configs")
}

/// Linked OAuth2 identity for an admin user. One admin can have multiple
/// linked providers (e.g. GitHub + Telegram). Used to match OAuth callbacks
/// to existing admin accounts.
model AdminOAuthLink {
  id            String           @id @default(cuid()) @map("id")
  adminUserId   String           @map("admin_user_id")
  providerType  AuthProviderType @map("provider_type")
  /// Provider-specific user identifier (GitHub user ID, Telegram ID, etc.).
  providerUserId String          @map("provider_user_id")
  /// Provider-supplied email (if available).
  providerEmail String?          @map("provider_email")
  /// Provider-supplied display name.
  providerName  String?          @map("provider_name")
  /// Raw profile data from the provider (sanitized).
  profileData   Json             @default("{}") @map("profile_data")
  linkedAt      DateTime         @default(now()) @map("linked_at") @db.Timestamptz(3)
  lastUsedAt    DateTime?        @map("last_used_at") @db.Timestamptz(3)

  @@unique([providerType, providerUserId])
  @@index([adminUserId])
  @@index([providerType])
  @@map("admin_oauth_links")
}

/// WebAuthn/Passkey credential stored for an admin user.
/// Each admin can register multiple passkeys (e.g. laptop + phone + YubiKey).
model AdminPasskey {
  id              String   @id @default(cuid()) @map("id")
  adminUserId     String   @map("admin_user_id")
  /// Human-readable name for the credential (e.g. "MacBook Pro", "YubiKey 5").
  name            String   @map("name")
  /// Base64url-encoded credential ID from the authenticator.
  credentialId    String   @unique @map("credential_id")
  /// Base64url-encoded public key (COSE format).
  publicKey       String   @map("public_key")
  /// Signature counter — incremented on each use, detects cloned keys.
  counter         BigInt   @default(0) @map("counter")
  /// Authenticator type: "platform" (built-in) or "cross-platform" (USB key).
  transports      String[] @default([]) @map("transports")
  /// Whether this credential is backed up (synced across devices).
  backedUp        Boolean  @default(false) @map("backed_up")
  /// AAGUID of the authenticator (identifies the make/model).
  aaguid          String?  @map("aaguid")
  registeredAt    DateTime @default(now()) @map("registered_at") @db.Timestamptz(3)
  lastUsedAt      DateTime? @map("last_used_at") @db.Timestamptz(3)

  @@index([adminUserId])
  @@map("admin_passkeys")
}
