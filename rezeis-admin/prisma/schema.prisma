//  PAYMENTS
// =============================================================================

model PaymentGateway {
  id         String             @id @default(cuid()) @map("id")
  type       PaymentGatewayType @unique @map("type")
  orderIndex Int                @default(0) @map("order_index")
  currency   Currency           @map("currency")
  isActive   Boolean            @default(false) @map("is_active")
  settings   Json               @default("{}") @map("settings")
  createdAt  DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([isActive])
  @@index([orderIndex])
  @@map("payment_gateways")
}

model Transaction {
  id             String             @id @default(cuid()) @map("id")
  /// Stable provider-facing payment identifier (UUID).
  paymentId      String             @unique @default(cuid()) @map("payment_id")
  userId         String             @map("user_id")
  subscriptionId String?            @map("subscription_id")
  status         TransactionStatus  @default(PENDING) @map("status")
  purchaseType   PurchaseType       @map("purchase_type")
  channel        PurchaseChannel    @default(WEB) @map("channel")
  gatewayType    PaymentGatewayType @map("gateway_type")
  /// Provider-side payment reference (e.g., YooKassa payment id).
  gatewayId      String?            @map("gateway_id")
  /// Optional raw provider payload kept for ops.
  gatewayData    Json?              @map("gateway_data")
  currency       Currency           @map("currency")
  paymentAsset   String?            @map("payment_asset")
  amount         Decimal            @map("amount") @db.Decimal(20, 8)
  /// Snapshot of the plan/duration at draft time.
  planSnapshot   Json               @default("{}") @map("plan_snapshot")
  deviceTypes    String[]           @default([]) @map("device_types")
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)

  user         User          @relation("UserTransactions", fields: [userId], references: [id], onDelete: Restrict)
  subscription Subscription? @relation("SubscriptionTransactions", fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([subscriptionId])
  @@index([status])
  @@index([gatewayType])
  @@index([purchaseType])
  @@index([createdAt])
  @@map("transactions")
}

/// Webhook ingress + reconciliation inbox. The lifecycle status is tracked
/// separately from the provider-supplied event status.
model PaymentWebhookEvent {
  id                     String                        @id @default(cuid()) @map("id")
  gatewayType            PaymentGatewayType            @map("gateway_type")
  /// Logical payment identifier (matches `Transaction.paymentId`).
  paymentId              String                        @map("payment_id")
  /// Provider-supplied event identifier (used for dedup).
  providerEventId        String                        @map("provider_event_id")
  /// Raw provider event status string, before normalization.
  eventStatus            String?                       @map("event_status")
  /// Internal lifecycle status used by the inbox/replay machinery.
  status                 PaymentWebhookLifecycleStatus @default(RECEIVED) @map("status")
  attempts               Int                           @default(1) @map("attempts")
  reconciliationAttempts Int                           @default(0) @map("reconciliation_attempts")
  replayCount            Int                           @default(0) @map("replay_count")
  lastError              String?                       @map("last_error")
  payloadHash            String?                       @map("payload_hash")
  rawPayload             Json                          @map("raw_payload")
  normalizedPayload      Json?                         @map("normalized_payload")
  receivedAt             DateTime                      @default(now()) @map("received_at") @db.Timestamptz(3)
  processedAt            DateTime?                     @map("processed_at") @db.Timestamptz(3)
  lastTransitionAt       DateTime                      @default(now()) @map("last_transition_at") @db.Timestamptz(3)
  lastReplayedAt         DateTime?                     @map("last_replayed_at") @db.Timestamptz(3)
  createdAt              DateTime                      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt              DateTime                      @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([gatewayType, providerEventId])
  @@index([gatewayType])
  @@index([status])
  @@index([paymentId])
  @@index([providerEventId])
  @@index([payloadHash])
  @@index([receivedAt])
  @@map("payment_webhook_events")
}

