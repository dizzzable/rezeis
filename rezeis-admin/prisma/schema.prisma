model Plan {
  id                   String                @id @default(cuid()) @map("id")
  orderIndex           Int                   @default(0) @map("order_index")
  isActive             Boolean               @default(true) @map("is_active")
  isArchived           Boolean               @default(false) @map("is_archived")
  type                 PlanType              @default(BOTH) @map("type")
  availability         PlanAvailability      @default(ALL) @map("availability")
  archivedRenewMode    ArchivedPlanRenewMode @default(SELF_RENEW) @map("archived_renew_mode")
  name                 String                @unique @map("name")
  description          String?               @map("description")
  tag                  String?               @map("tag")
  trafficLimit         Int?                  @map("traffic_limit")
  deviceLimit          Int                   @default(0) @map("device_limit")
  trafficLimitStrategy TrafficLimitStrategy  @default(NO_RESET) @map("traffic_limit_strategy")
  /// Plans available as upgrade targets from this plan.
  upgradeToPlanIds     String[]              @default([]) @map("upgrade_to_plan_ids")
  /// Plans that may replace this archived plan during renewal.
  replacementPlanIds   String[]              @default([]) @map("replacement_plan_ids")
  /// Explicit allowlist of users for `availability = ALLOWED`.
  allowedUserIds       String[]              @default([]) @map("allowed_user_ids")
  internalSquads       String[]              @default([]) @map("internal_squads")
  externalSquad        String?               @map("external_squad")
  createdAt            DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)

  durations PlanDuration[]

  @@index([isActive])
  @@index([isArchived])
  @@index([availability])
  @@index([orderIndex])
  @@map("plans")
}

model PlanDuration {
  id       String  @id @default(cuid()) @map("id")
  planId   String  @map("plan_id")
  days     Int     @map("days")
  isActive Boolean @default(true) @map("is_active")

  plan   Plan        @relation(fields: [planId], references: [id], onDelete: Cascade)
  prices PlanPrice[]

  @@index([planId])
  @@map("plan_durations")
}

model PlanPrice {
  id             String   @id @default(cuid()) @map("id")
  planDurationId String   @map("plan_duration_id")
  currency       Currency @map("currency")
  price          Decimal  @map("price") @db.Decimal(20, 8)

  planDuration PlanDuration @relation(fields: [planDurationId], references: [id], onDelete: Cascade)

  @@unique([planDurationId, currency])
  @@index([planDurationId])
  @@index([currency])
  @@map("plan_prices")
}

