// =============================================================================
//  ADMIN USERS & AUDIT
// =============================================================================

/// Authenticated admin operator. The first DEV admin is bootstrapped via
/// `/api/internal/auth/bootstrap-first-admin` when the table is empty.
model AdminUser {
  id                 String    @id @default(cuid()) @map("id")
  login              String    @map("login")
  loginNormalized    String    @unique @map("login_normalized")
  email              String?   @unique @map("email")
  passwordHash       String    @map("password_hash")
  name               String?   @map("name")
  role               UserRole  @default(ADMIN) @map("role")
  isActive           Boolean   @default(true) @map("is_active")
  /// Incremented on password change / session revoke — invalidates old JWTs.
  tokenVersion       Int       @default(0) @map("token_version")
  lastLoginAt        DateTime? @map("last_login_at") @db.Timestamptz(3)
  lastLoginIp        String?   @map("last_login_ip")
  passwordChangedAt  DateTime? @map("password_changed_at") @db.Timestamptz(3)
  /// Forces the admin to change their password on next sign-in. Set when an
  /// operator resets a password or imports a new admin with a temporary one.
  mustChangePassword Boolean   @default(false) @map("must_change_password")
  /// Optional pointer to a custom RBAC role. When `null` the admin still
  /// gets the implicit permissions tied to their `role` enum (DEV --> all,
  /// ADMIN --> safe-write defaults). When set the role's permission matrix
  /// fully replaces the legacy `role`-derived defaults.
  rbacRoleId         String?   @map("rbac_role_id")
  ///
  /// ── 2FA (TOTP) — Phase 5 ──────────────────────────────────────────
  ///
  /// `true` once the admin has finished the TOTP enrollment flow. Until
  /// then `totpSecretEncrypted` is empty and login skips the second-factor
  /// step. Operators with `totpEnabled = true` MUST present a valid 6-digit
  /// code on every login and on every privileged action that re-prompts.
  totpEnabled        Boolean   @default(false) @map("totp_enabled")
  /// AES-256-GCM-encrypted Base32 TOTP secret. Encryption key is derived
  /// from REZEIS_CRYPT_KEY so the database alone does not expose secrets.
  /// Format: `iv:ciphertext:tag`, all hex-encoded.
  totpSecretEncrypted String?  @map("totp_secret_encrypted")
  /// SHA-256 hashes of single-use TOTP recovery codes. Stored as a string
  /// array; each value is consumed (removed) on use. We store hashes only;
  /// the plaintext codes are shown to the operator exactly once during
  /// enrollment.
  totpRecoveryCodes  String[]  @default([]) @map("totp_recovery_codes")
  totpEnrolledAt     DateTime? @map("totp_enrolled_at") @db.Timestamptz(3)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  auditLogs     AdminAuditLog[]    @relation("AdminAuditLogActor")
  rbacRole      AdminRole?         @relation("AdminUserRbacRole", fields: [rbacRoleId], references: [id], onDelete: SetNull)
  scopePolicies AdminScopePolicy[] @relation("AdminUserScopePolicy")
  themePresets  AdminThemePreset[] @relation("AdminThemePresetOwner")

  @@index([role])
  @@index([isActive])
  @@index([rbacRoleId])
  @@map("admin_users")
}

/// AdminThemePreset
/// ────────────────
/// Saved appearance preset (preset id, custom CSS, per-token overrides,
/// radius). Owned by an admin; can optionally be shared with the rest of
/// the team via `isShared = true`.
model AdminThemePreset {
  id          String   @id @default(cuid()) @map("id")
  ownerId     String   @map("owner_id")
  name        String   @map("name")
  description String?  @map("description")
  isShared    Boolean  @default(false) @map("is_shared")
  /// Snapshot of the appearance state — `presetId`, `customCss`,
  /// `overridesLight`, `overridesDark`, `radius`. Validated and shaped
  /// in `theme-preset.dto.ts`.
  themeData   Json     @map("theme_data")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  owner AdminUser @relation("AdminThemePresetOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([isShared])
  @@map("admin_theme_presets")
}

/// Append-only audit trail of admin actions.
model AdminAuditLog {
  id          String   @id @default(cuid()) @map("id")
  /// Free-form action identifier, e.g. "admin.login.succeeded", "plans.created".
  action      String   @map("action")
  adminUserId String?  @map("admin_user_id")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  metadata    Json     @default("{}") @map("metadata")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  adminUser AdminUser? @relation("AdminAuditLogActor", fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([adminUserId])
  @@index([createdAt])
  @@map("admin_audit_log")
}

// =============================================================================
//  PHASE 5 — Login Guard + Admin IP Allowlist
// =============================================================================

/// Single login attempt against `/admin/auth/login`. Inserted on every
/// success and failure so the LoginGuard service can detect brute-force
/// patterns by counting recent failures per (login, ip) tuple.
///
/// Retention: cleaned up by the Phase 5 daily cron — see
/// `LoginGuardService.cleanupOldAttempts()`.
model AdminLoginAttempt {
  id           String   @id @default(cuid()) @map("id")
  /// Normalised login as supplied by the client. Empty string means the
  /// guard rejected the request before we read the body.
  loginNormalized String   @default("") @map("login_normalized")
  ipAddress    String   @map("ip_address")
  /// `true` for successful authentications. We keep both successes and
  /// failures so the audit UI can render "last successful login from this
  /// IP" in addition to failure spikes.
  success      Boolean  @default(false) @map("success")
  /// Short reason code: `invalid_password`, `admin_not_found`, `ip_blocked`,
  /// `rate_limited`, `totp_required`, `totp_invalid`, etc.
  reason       String?  @map("reason")
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([loginNormalized, createdAt])
  @@index([ipAddress, createdAt])
  @@index([success, createdAt])
  @@map("admin_login_attempts")
}

/// Admin panel IP allowlist. When the table contains at least one row,
/// the panel switches into "allowlist mode": only requests originating
/// from a listed address (or CIDR range) may reach `/api/admin/*`.
///
/// Admins can still be added/removed by the local CLI as a recovery
/// mechanism (see scripts/admin-cli.ts in Phase 9). The active flag lets
/// operators temporarily disable an entry without deleting it.
model AdminIpAllowlist {
  id          String    @id @default(cuid()) @map("id")
  /// Single IPv4/IPv6 address or CIDR range (`1.2.3.0/24`, `2001:db8::/32`).
  address     String    @unique @map("address")
  /// Free-form label visible in the admin UI (e.g. `Office VPN`,
  /// `Operator-Anna-home`). No PII expected.
  label       String    @default("") @map("label")
  /// `true` to enforce the entry; `false` lets operators stage-add an
  /// address without enabling it yet.
  isActive    Boolean   @default(true) @map("is_active")
  /// Pointer to the admin who created the entry.
  createdById String?   @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([isActive])
  @@index([createdAt])
  @@map("admin_ip_allowlist")
}

/// IP-based access blocklist. Used by the admin panel to deny requests from
/// abusive sources (manual `/blocking` entries) and by automated rules
/// (Phase 2: anti-fraud action `block_ip`).
///
/// Address can be a single IPv4/IPv6 address or a CIDR range. We store it
/// as a free-form string so tooling can normalise into the format that best
/// fits the consumer (rate-limit middleware, fail2ban-style filters, etc.).
model BlockedIp {
  id          String    @id @default(cuid()) @map("id")
  /// Single address (`1.2.3.4`) or CIDR (`1.2.3.0/24`).
  address     String    @unique @map("address")
  /// Operator-supplied or rule-supplied reason. Free-form, no PII expected.
  reason      String?   @map("reason")
  /// `manual` for human entries, `automation` for rule-emitted entries.
  source      String    @default("manual") @map("source")
  /// Optional pointer to the admin who created the entry.
  createdById String?   @map("created_by_id")
  /// When the block expires. `null` means permanent.
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz(3)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([source])
  @@index([expiresAt])
  @@index([createdAt])
  @@map("blocked_ips")
}

// =============================================================================
//  PHASE 6 — Webhook Subscriptions + Delivery History
// =============================================================================

/// Lifecycle status of a webhook delivery attempt.
enum WebhookDeliveryStatus {
  PENDING
  SUCCEEDED
  FAILED
  RETRYING
}

/// Outgoing webhook subscription — lets external services receive HMAC-
/// signed POST requests when SystemEvents fire (`payment.completed`,
/// `subscription.created`, `user.blocked`, …).
///
/// Identity & secrets
///   Each subscription owns its own random secret (`secret`). The secret
///   is stored as a 64-char hex string and used to compute an HMAC-SHA256
///   of the body. The wire signature header follows Stripe's format:
///
///     X-Rezeis-Signature: t=<unix-ts>,v1=<hex-hmac>
///
///   Receivers verify both the timestamp (replay protection) and the
///   HMAC. The leading `t=` element is part of the signed payload:
///     `<timestamp>.<body>`
///
/// Filtering
///   `eventTypes` is a list of either exact event types
///   (`payment.completed`) or simple wildcards (`payment.*`, `*`).
///   Empty list means "every event".
///
/// Auto-disable
///   `consecutiveFailures` is incremented on every failed delivery and
///   reset to 0 on success. When it crosses
///   `WebhookDispatcherService.AUTO_DISABLE_THRESHOLD`, the row's
///   `isActive` flips to `false` and the operator gets a notification.
model WebhookSubscription {
  id                  String    @id @default(cuid()) @map("id")
  /// Operator-supplied label visible in the UI.
  name                String    @map("name")
  url                 String    @map("url")
  /// Hex-encoded random secret used to sign payloads. Generated server
  /// side on create — operators may rotate it (regenerate endpoint).
  secret              String    @map("secret")
  /// Filter — empty array OR `[*]` matches every event.
  eventTypes          String[]  @default([]) @map("event_types")
  /// Optional human-readable description.
  description         String?   @map("description")
  isActive            Boolean   @default(true) @map("is_active")
  /// Pointer to the admin who created the entry.
  createdById         String?   @map("created_by_id")
  /// Last successful delivery — used by the dashboard to flag stale endpoints.
  lastDeliveredAt     DateTime? @map("last_delivered_at") @db.Timestamptz(3)
  /// Counter that drives auto-disable.
  consecutiveFailures Int       @default(0) @map("consecutive_failures")
  /// Total deliveries attempted (success + fail), maintained on every
  /// dispatch so list views don't need a JOIN/COUNT on the deliveries table.
  totalDeliveries     Int       @default(0) @map("total_deliveries")
  totalFailures       Int       @default(0) @map("total_failures")
  /// Operator-disabled bit — set when the dispatcher hits the
  /// auto-disable threshold. Distinct from `isActive` (which the operator
  /// toggles manually) so we can show "auto-disabled, requires attention".
  autoDisabledAt      DateTime? @map("auto_disabled_at") @db.Timestamptz(3)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  deliveries WebhookDelivery[] @relation("WebhookSubscriptionDeliveries")

  @@index([isActive])
  @@index([createdAt])
  @@map("webhook_subscriptions")
}

/// One delivery attempt against a webhook endpoint. Inserted once per
/// (subscription, event) tuple as `PENDING` and updated to
/// `SUCCEEDED` / `FAILED` / `RETRYING` by the BullMQ processor.
///
/// Retention: the daily cleanup cron (in `WebhookDispatcherService`) drops
/// rows older than 30 days so the table stays bounded.
model WebhookDelivery {
  id              String                @id @default(cuid()) @map("id")
  subscriptionId  String                @map("subscription_id")
  /// SystemEvents event type ("payment.completed" etc.).
  eventType       String                @map("event_type")
  /// JSON payload that was POSTed (or will be). Kept for "Replay" feature
  /// from the UI.
  payload         Json                  @map("payload")
  status          WebhookDeliveryStatus @default(PENDING) @map("status")
  attempt         Int                   @default(0) @map("attempt")
  /// HTTP status from the last attempt. `null` while pending.
  httpStatus      Int?                  @map("http_status")
  /// First few chars of the response body for diagnostics. Always
  /// truncated to `MAX_RESPONSE_BODY_PREVIEW` chars to keep storage
  /// predictable.
  responseBody    String?               @map("response_body")
  /// Last error message (transport-level — DNS, timeout, TLS, …).
  errorMessage    String?               @map("error_message")
  /// Round-trip time in ms, populated on completion.
  durationMs      Int?                  @map("duration_ms")
  /// When the next retry is scheduled. `null` once the delivery is
  /// terminal (SUCCEEDED or FAILED with no more retries).
  nextRetryAt     DateTime?             @map("next_retry_at") @db.Timestamptz(3)
  startedAt       DateTime?             @map("started_at") @db.Timestamptz(3)
  finishedAt      DateTime?             @map("finished_at") @db.Timestamptz(3)
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)

  subscription WebhookSubscription @relation("WebhookSubscriptionDeliveries", fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, createdAt])
  @@index([status, createdAt])
  @@index([eventType])
  @@map("webhook_deliveries")
}

/// IP-based access blocklist. Used by the admin panel to deny requests from
/// abusive sources (manual `/blocking` entries) and by automated rules
/// (Phase 2: anti-fraud action `block_ip`).
///
/// (Re-stated header — body lives above on `model BlockedIp`.)

// =============================================================================
//  RBAC — Custom roles, permissions, scope policies
// =============================================================================

/// Custom RBAC role. Optional supplement to the legacy `UserRole` enum on
/// `AdminUser`: when a role is attached, the role's permission matrix
/// fully drives access checks; the `role` enum is kept only for backwards
/// compatibility (DEV admins always see everything regardless of RBAC).
///
/// `isSystem` marks role rows that the application provisions on startup
/// (e.g. "Operator", "Support") and refuses to delete from the UI.
model AdminRole {
  id          String   @id @default(cuid()) @map("id")
  name        String   @unique @map("name")
  displayName String   @map("display_name")
  description String?  @map("description")
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  permissions AdminPermission[] @relation("AdminRolePermissions")
  admins      AdminUser[]       @relation("AdminUserRbacRole")

  @@map("admin_roles")
}

/// One row per (role × resource × action). The set of (resource, action)
/// pairs is derived at runtime from `RBAC_RESOURCES` in
/// `web/backend/api/v2/roles.py`-equivalent — for rezeis-admin it lives in
/// `src/modules/rbac/rbac.resources.ts` and is the only authoritative
/// source. The DB does not enforce the values; that is the job of the
/// RBAC service which validates writes.
model AdminPermission {
  id        String   @id @default(cuid()) @map("id")
  roleId    String   @map("role_id")
  resource  String   @map("resource")
  action    String   @map("action")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  role AdminRole @relation("AdminRolePermissions", fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, resource, action])
  @@index([roleId])
  @@map("admin_permissions")
}

/// Scope policy attaches a whitelist of resource UUIDs / tags to either a
/// role or a single admin. Used by the access-policy resolver to filter
/// admin lists (only see plans X/Y, only see gateway YOOKASSA, …).
///
/// At least one of `roleId` / `adminUserId` must be set; the resolver
/// merges policies from both sources.
model AdminScopePolicy {
  id           String   @id @default(cuid()) @map("id")
  /// Optional role — when set, the policy applies to every admin with
  /// that role.
  roleId       String?  @map("role_id")
  /// Optional single-admin override.
  adminUserId  String?  @map("admin_user_id")
  /// Logical resource type the policy targets (e.g. `plan`, `gateway`,
  /// `partner`). The reader is tolerant of unknown values and treats them
  /// as a no-op.
  resourceType String   @map("resource_type")
  /// Either an explicit UUID (`scopeType=uuid`) or a tag/label
  /// (`scopeType=tag`) the resource belongs to.
  scopeType    String   @map("scope_type")
  scopeValue   String   @map("scope_value")
  /// Comma-joined list of allowed actions (`view`, `edit`, `delete`).
  /// `view` is implied by every other action so we keep the list short.
  actions      String   @map("actions")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  adminUser AdminUser? @relation("AdminUserScopePolicy", fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([roleId])
  @@index([adminUserId])
  @@index([resourceType])
  @@map("admin_scope_policies")
}

// =============================================================================
//  FRAUD SIGNALS — Persistent anti-fraud findings
// =============================================================================

/// Severity of a fraud signal. Drives badge colour and default action.
enum FraudSignalSeverity {
  LOW
  MEDIUM
  HIGH
}

/// Lifecycle status of a fraud signal. Created in `OPEN`; an operator
/// transitions it to `ACKNOWLEDGED`, `RESOLVED`, or `DISMISSED`. Automated
/// actions (notify, block_user, freeze_subscription) annotate the row but
/// never change its status — that remains an explicit operator decision.
enum FraudSignalStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  DISMISSED
}

/// Persistent anti-fraud finding emitted by the AntiFraudService detectors
/// or by automation rules. Replaces the previous stateless "report" so the
/// admin UI can show history, track resolution, and avoid duplicate alerts.
///
/// Identity / dedup
///   `code` is the detector identifier (e.g. `EXCESSIVE_FAILED_PAYMENTS`).
///   The `(code, fingerprint)` composite is unique while the signal is
///   open — this prevents the scheduler from re-creating the same alert
///   on every tick. `fingerprint` is detector-defined (typically a hash
///   of the affected user ids + time bucket).
///
/// Scoring
///   `score` is a normalised 0-100 risk metric. `confidence` (0-100)
///   measures how certain the detector is. The frontend can sort by
///   `score * confidence / 100` for a composite priority.
model FraudSignal {
  id              String              @id @default(cuid()) @map("id")
  code            String              @map("code")
  /// Detector-defined deduplication fingerprint. Empty string means
  /// "always create a new row".
  fingerprint     String              @default("") @map("fingerprint")
  severity        FraudSignalSeverity @map("severity")
  status          FraudSignalStatus   @default(OPEN) @map("status")
  title           String              @map("title")
  description     String              @map("description")
  /// Risk score (0-100). Detectors may use any reasonable mapping.
  score           Int                 @default(0) @map("score")
  /// Confidence (0-100) — how certain the detector is.
  confidence      Int                 @default(100) @map("confidence")
  /// Affected user ids (CUIDs from `users`). Lookup-by-user-id index lives
  /// on the JSON column — admin UI only filters by status/code/severity.
  affectedUserIds String[]            @default([]) @map("affected_user_ids")
  /// Free-form metadata the detector wants to surface in the UI
  /// (counts, thresholds, time window, …). No PII.
  metadata        Json                @default("{}") @map("metadata")
  /// Last automated action taken: 'notify' | 'block_user' |
  /// 'freeze_subscription' | 'none'.
  lastAction      String              @default("none") @map("last_action")
  detectedAt      DateTime            @default(now()) @map("detected_at") @db.Timestamptz(3)
  resolvedAt      DateTime?           @map("resolved_at") @db.Timestamptz(3)
  resolvedBy      String?             @map("resolved_by")
  resolutionNote  String?             @map("resolution_note")
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([code, fingerprint])
  @@index([status])
  @@index([severity])
  @@index([code])
  @@index([detectedAt])
  @@map("fraud_signals")
}

// =============================================================================
//  AUTOMATIONS — IFTTT-style rule engine
// =============================================================================

/// Trigger phase of a rule. `realtime` → fires on a SystemEvents event;
/// `cron` → fires on a wall-clock schedule defined by `triggerSchedule`.
/// `manual` → only when an operator clicks "Run now".
enum AutomationTriggerKind {
  REALTIME
  CRON
  MANUAL
}

/// Lifecycle status of a single execution.
enum AutomationExecutionStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  SKIPPED
}

/// A single automation rule.
///
/// Composition
///   - `trigger` → `kind` + (cron expression OR event name pattern).
///   - `conditions` → JSON expression evaluated against the trigger payload.
///     The evaluator supports a tiny subset of JSON-logic:
///       { "and": [ {"==": ["$severity", "HIGH"]}, {">": ["$score", 70]} ] }
///   - `actions` → ordered JSON array of action objects:
///       [ { "type": "notify_telegram", "params": {...} } ]
///
/// The rule engine is intentionally minimal — it ships with five built-in
/// action types (`notify_telegram`, `webhook_post`, `block_ip`,
/// `system_event`, `block_user`) and a hand-written JSON-logic evaluator
/// in `automation/utils/expression-evaluator.ts`. Adding a new action is a
/// backend-only change.
model AutomationRule {
  id             String                     @id @default(cuid()) @map("id")
  name           String                     @map("name")
  description    String?                    @map("description")
  isEnabled      Boolean                    @default(true) @map("is_enabled")
  triggerKind    AutomationTriggerKind      @map("trigger_kind")
  /// REALTIME --> event-type pattern (e.g. payment.failed, fraud.*).
  /// CRON     --> cron expression (e.g. zero-zero star slash six star).
  /// MANUAL   --> empty string.
  triggerSpec    String                     @default("") @map("trigger_spec")
  /// Condition tree (JSON-logic-ish). null means "always match".
  conditions     Json?                      @map("conditions")
  /// Ordered list of actions executed when the rule fires.
  actions        Json                       @default("[]") @map("actions")
  /// Pointer to the admin who created the rule. Used for audit.
  createdById    String?                    @map("created_by_id")
  /// Last execution outcome cache - kept here so list views do not need
  /// to join automation_executions for every row.
  lastRunAt      DateTime?                  @map("last_run_at") @db.Timestamptz(3)
  lastRunStatus  AutomationExecutionStatus? @map("last_run_status")
  lastRunMessage String?                    @map("last_run_message")
  /// Total number of times the rule has fired (incl. failures). Useful
  /// for the operator dashboard.
  runCount       Int                        @default(0) @map("run_count")
  createdAt      DateTime                   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(3)

  executions AutomationExecution[] @relation("AutomationExecutionRule")

  @@index([isEnabled])
  @@index([triggerKind])
  @@map("automation_rules")
}

/// One execution of an automation rule. Stores enough context to debug
/// after the fact: trigger payload, action results, error messages.
model AutomationExecution {
  id             String                    @id @default(cuid()) @map("id")
  ruleId         String                    @map("rule_id")
  status         AutomationExecutionStatus @default(PENDING) @map("status")
  /// Why the execution started (`event:payment.failed`, `cron`, `manual:<adminId>`).
  trigger        String                    @map("trigger")
  /// Trigger payload (event metadata, cron tick info, …) for debugging.
  triggerPayload Json                      @default("{}") @map("trigger_payload")
  /// Per-action results recorded as `{ index, type, status, message? }`.
  actionResults  Json                      @default("[]") @map("action_results")
  errorMessage   String?                   @map("error_message")
  startedAt      DateTime?                 @map("started_at") @db.Timestamptz(3)
  finishedAt     DateTime?                 @map("finished_at") @db.Timestamptz(3)
  durationMs     Int?                      @map("duration_ms")
  createdAt      DateTime                  @default(now()) @map("created_at") @db.Timestamptz(3)

  rule AutomationRule @relation("AutomationExecutionRule", fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@index([status])
  @@index([createdAt])
  @@map("automation_executions")
}

