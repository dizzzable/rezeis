DB_HOST=postgres
DB_PORT=5432
DB_NAME=rezeis
DB_USER=rezeis
DB_PASSWORD=rezeis_secret
DATABASE_URL=postgresql://rezeis:rezeis_secret@postgres:5432/rezeis

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# Used to encrypt sensitive values stored from the Admin Panel.
# Payment gateways credentials are configured in the Admin Panel and encrypted with APP_CRYPT_KEY.
APP_CRYPT_KEY=change-me-app-crypt-key

REZEIS_ADMIN_JWT_SECRET=change-me-admin-jwt-secret
REZEIS_ADMIN_INTERNAL_API_KEY=change-me-admin-internal-api-key

# Admin-side SMTP delivery for linked-account email verification codes.
REZEIS_ADMIN_SMTP_HOST=smtp.example.com
REZEIS_ADMIN_SMTP_PORT=465
REZEIS_ADMIN_SMTP_SECURE=true
# Leave both empty for providers that allow unauthenticated SMTP relay.
REZEIS_ADMIN_SMTP_USER=change-me-smtp-user
REZEIS_ADMIN_SMTP_PASSWORD=change-me-smtp-password
REZEIS_ADMIN_SMTP_FROM_ADDRESS=no-reply@example.com
REZEIS_ADMIN_SMTP_FROM_NAME=Rezeis Admin
REZEIS_ADMIN_SMTP_REPLY_TO=support@example.com
# Optional override for EHLO / Message-ID domain. Defaults to the domain from REZEIS_ADMIN_SMTP_FROM_ADDRESS.
REZEIS_ADMIN_SMTP_IDENTITY_DOMAIN=
REZEIS_ADMIN_SMTP_TIMEOUT_MS=10000

# Telegram auth/session settings for ruid-api.
# Local HTTP development must override secure cookies explicitly or the browser will not persist them.
TELEGRAM_AUTH_MAX_AGE_SECONDS=300
RUID_SESSION_TTL_SECONDS=604800
RUID_SESSION_COOKIE_NAME=ruid_session
RUID_SESSION_COOKIE_SECURE=false
RUID_SESSION_COOKIE_DOMAIN=
RUID_SESSION_COOKIE_PATH=/
RUID_SESSION_COOKIE_SAMESITE=lax

# - - - - - REZEIS INTERNAL CONFIGURATION - - - - - #

REZEIS_BASE_URL=
REZEIS_HOST=rezeis-admin-api
REZEIS_PORT=3000
REZEIS_TOKEN=change_me
REZEIS_WEBHOOK_SECRET=change_me

# Vite dev proxy target for same-origin /api calls from ruid/web.
# Use http://localhost:8100 when running Vite on the host.
VITE_DEV_API_PROXY_TARGET=http://ruid-api:8000

# Optional extra browser origins allowed to call credentialed ruid-api endpoints.
# Keep empty for same-origin/proxied local dev, or add comma-separated origins for split web/API dev.
RUID_BROWSER_ALLOWED_ORIGINS=

# - - - - - REMNAWAVE CONFIGURATION - - - - - #

# !!! CRITICALLY IMPORTANT !!!
# For correct operation, the bot webhook must be configured.
# Set WEBHOOK_ENABLED and WEBHOOK_URL in the Remnawave Panel's .env file
# to point to your bot endpoint, for example:
# https://bot.domain.com/api/v1/remnawave
# !!! CRITICALLY IMPORTANT !!!

# Hostname or Docker service name for connecting to the Remnawave API.
# !!! WARNING: Specify domain WITHOUT HTTP/HTTPS and WITHOUT trailing slash,
# or use the Docker container name.
REMNAWAVE_HOST=remnawave

# Port number for connecting to the Remnawave API.
# Only required if the panel is running on the same server in Docker.
REMNAWAVE_PORT=3000

# API token for authenticating with the Remnawave service.
# !!! CRITICALLY IMPORTANT: Keep this token secret and never expose it publicly.
REMNAWAVE_TOKEN=change_me

# Secret token for verifying incoming webhooks from Remnawave.
# In the Remnawave Panel, this corresponds to WEBHOOK_SECRET_HEADER.
REMNAWAVE_WEBHOOK_SECRET=change_me

# If using Remnawave behind Caddy with authentication enabled,
# specify the X-Api-Key value expected by Caddy for authorized access.
# This token will be included in requests sent to the Remnawave API.
REMNAWAVE_CADDY_TOKEN=

# Custom cookie for authentication with Remnawave.
# Must be in the format 'name=value' (e.g., wDpdagIh=T4yWkD8rM1oF).
REMNAWAVE_COOKIE=

# - - - - - BOT CONFIGURATION - - - - - #

# Telegram Bot API token. Obtain it from https://t.me/BotFather/
# !!! CRITICALLY IMPORTANT: Never share this token publicly. It grants full control over your bot.
BOT_TOKEN=change_me

# Secret token for webhook verification. Ensures webhook requests originate from Telegram.
BOT_SECRET_TOKEN=change_me

# Developer Telegram user ID. Grants elevated permissions.
BOT_DEV_ID=change_me

# Telegram username of the support account used for deep-linking (without @).
BOT_SUPPORT_USERNAME=change_me

# Controls the behavior of the "connect" button:
# - empty or false  -> opens the subscription page in the browser
# - true            -> opens the subscription page in WebApp
# - URL (e.g., https://example.com/) -> opens the specified URL in WebApp
# Recommended for Telegram Mini App entrypoint in the current routed shell:
# - http://localhost:5173/ when running Vite on the host
# - https://yourdomain.com/ for deployed environments
# The web shell now bootstraps a cookie-backed session from Telegram init data.
# Keep BOT_MINI_APP on the exact public origin served by ruid-web so bootstrap and cookie reads stay same-origin in dev.
# To use the subscription page, deploy the remnawave-subscription-page:
#   https://docs.rw/docs/install/remnawave-subscription-page
# To use a custom subscription page (Orion):
#   https://github.com/legiz-ru/Orion
# To use the Mini App (Maposia):
#   https://github.com/maposia/remnawave-telegram-sub-mini-app
BOT_MINI_APP=http://localhost:5173/

# Whether to remove the bot's webhook on shutdown.
# Set to 'true' to delete the webhook automatically.
# Set to 'false' to keep it active (the bot checks its validity on startup).
BOT_RESET_WEBHOOK=false

# Whether to drop pending (unprocessed) updates when the bot restarts.
# Set to 'true' to ignore outdated messages.
BOT_DROP_PENDING_UPDATES=false

# Whether to set standard bot commands (/start, /help) in Telegram on startup.
BOT_SETUP_COMMANDS=true

# Whether to enable banners usage.
BOT_USE_BANNERS=true

# Whether to setup Telegram webhook on startup.
# Set to 'false' for local development or if webhook is managed externally.
BOT_SETUP_WEBHOOK=false

TELEGRAM_ADMIN_CHAT_ID=
