DB_HOST=postgres
DB_PORT=5432
DB_NAME=rezeis
DB_USER=rezeis
DB_PASSWORD=rezeis_secret
DATABASE_URL=postgresql://rezeis:rezeis_secret@postgres:5432/rezeis

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

REZEIS_ADMIN_JWT_SECRET=change-me-admin-jwt-secret
REZEIS_ADMIN_INTERNAL_API_KEY=change-me-admin-internal-api-key

# Admin-side SMTP delivery for linked-account email verification codes.
REZEIS_ADMIN_SMTP_HOST=smtp.example.com
REZEIS_ADMIN_SMTP_PORT=465
REZEIS_ADMIN_SMTP_SECURE=true
# Leave both empty for providers that allow unauthenticated SMTP relay.
REZEIS_ADMIN_SMTP_USER=change-me-smtp-user
REZEIS_ADMIN_SMTP_PASSWORD=change-me-smtp-password
REZEIS_ADMIN_SMTP_FROM_ADDRESS=no-reply@example.com
REZEIS_ADMIN_SMTP_FROM_NAME=Rezeis Admin
REZEIS_ADMIN_SMTP_REPLY_TO=support@example.com
# Optional override for EHLO / Message-ID domain. Defaults to the domain from REZEIS_ADMIN_SMTP_FROM_ADDRESS.
REZEIS_ADMIN_SMTP_IDENTITY_DOMAIN=
REZEIS_ADMIN_SMTP_TIMEOUT_MS=10000

# Telegram auth/session settings for ruid-api.
# Production-like example: short-lived Telegram initData validation, long-lived opaque session cookie.
TELEGRAM_AUTH_MAX_AGE_SECONDS=300
RUID_SESSION_TTL_SECONDS=604800
RUID_SESSION_COOKIE_NAME=ruid_session
RUID_SESSION_COOKIE_SECURE=true
RUID_SESSION_COOKIE_DOMAIN=
RUID_SESSION_COOKIE_PATH=/
RUID_SESSION_COOKIE_SAMESITE=lax

# RUID -> rezeis-admin internal access
REZEIS_BASE_URL=
REZEIS_HOST=rezeis-admin-api
REZEIS_PORT=3000

# Public user-side URLs
RUID_PUBLIC_WEB_URL=https://user.example.com

# Optional extra browser origins allowed to call credentialed ruid-api endpoints.
# Use a comma-separated list when ruid-web is served from additional origins beyond RUID_PUBLIC_WEB_URL.
RUID_BROWSER_ALLOWED_ORIGINS=

# - - - - - BOT CONFIGURATION - - - - - #

# Telegram Bot API token. Obtain it from https://t.me/BotFather/
# !!! CRITICALLY IMPORTANT: Never share this token publicly. It grants full control over your bot.
BOT_TOKEN=change_me

# Secret token for webhook verification. Ensures webhook requests originate from Telegram.
BOT_SECRET_TOKEN=change_me

# Developer Telegram user ID. Grants elevated permissions.
BOT_DEV_ID=change_me

# Telegram username of the support account used for deep-linking (without @).
BOT_SUPPORT_USERNAME=change_me

# Telegram Mini App entrypoint for the current routed shell.
# The web shell now boots an opaque cookie session from Telegram init data, so use the exact public ruid-web origin here.
# Keep this on the same public origin that will receive the secure session cookie.
BOT_MINI_APP=https://user.example.com/

# Whether to remove the bot's webhook on shutdown.
# Set to 'true' to delete the webhook automatically.
# Set to 'false' to keep it active (the bot checks its validity on startup).
BOT_RESET_WEBHOOK=false

# Whether to drop pending (unprocessed) updates when the bot restarts.
# Set to 'true' to ignore outdated messages.
BOT_DROP_PENDING_UPDATES=false

# Whether to set standard bot commands (/start, /help) in Telegram on startup.
BOT_SETUP_COMMANDS=true

# Whether to enable banners usage.
BOT_USE_BANNERS=true

# Whether to setup Telegram webhook on startup.
# Set to 'false' for local development or if webhook is managed externally.
BOT_SETUP_WEBHOOK=false

TELEGRAM_ADMIN_CHAT_ID=
