# ═══════════════════════════════════════════════════════════════════════════════
#  reiwa — Environment Configuration
#
#  Reiwa is the user-facing edge service for Rezeis.
#  It connects to rezeis-admin for all business logic.
#
#  Copy this file to .env and fill in the values marked with "change_me".
# ═══════════════════════════════════════════════════════════════════════════════

# - - - - - REIWA CONFIGURATION - - - - - #
REIWA_DOMAIN=change_me
REIWA_HOST=0.0.0.0
REIWA_PORT=5000
REIWA_LOCALES=ru,en
REIWA_DEFAULT_LOCALE=ru

# - - - - - REZEIS CONFIGURATION - - - - - #
# Connection to rezeis-admin panel (source of truth for all business logic)
REZEIS_HOST=rezeis-admin
REZEIS_PORT=8000
REZEIS_TOKEN=change_me
REZEIS_CADDY_TOKEN=
REZEIS_COOKIE=

# - - - - - BOT CONFIGURATION - - - - - #
BOT_MINI_APP=false
BOT_SUPPORT_USERNAME=change_me
BOT_DEV_ID=change_me
BOT_SECRET_TOKEN=change_me
BOT_TOKEN=change_me
# Telegram bot username WITHOUT the leading "@", e.g. RezeisBot.
# Used to build the t.me/<BOT_USERNAME>?start=payment_return deep link that
# brings users back to the bot (and into the Mini App via menu button)
# after returning from a payment provider in Telegram context.
BOT_USERNAME=RezeisBot
BOT_RESET_WEBHOOK=false
BOT_DROP_PENDING_UPDATES=false
BOT_SETUP_COMMANDS=true
BOT_SETUP_WEBHOOK=false

# - - - - - DATABASE - - - - - #
# reiwa is a stateless edge service. The Postgres source of truth lives in
# rezeis-admin and is reached over HTTP via REZEIS_HOST / REZEIS_PORT.
# Reiwa keeps no relational state of its own. All ephemeral state
# (sessions, rate-limit counters, FSM, linking codes, install banners)
# lives in reiwa-redis below.

# - - - - - REDIS CONFIGURATION - - - - - #
# Reiwa's own Redis (sessions, rate limiting, bot FSM state)
REDIS_HOST=reiwa-redis
REDIS_PORT=6379
REDIS_NAME=0
REDIS_PASSWORD=change_me

